<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dc="using:Dock.Avalonia.Controls"
        x:Class="Agnes.App.Desktop.MainWindow"
        Title="Agnes" Width="1180" Height="760"
        MinWidth="720" MinHeight="480"
        Background="{StaticResource Bg}"
        FontFamily="{StaticResource UiFont}">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+T" Command="{Binding NewTabCommand}" />
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseActiveTabCommand}" />
    </Window.KeyBindings>

    <Grid RowDefinitions="Auto,*">

        <!-- Top bar: title + new-tab (browser-style) -->
        <Border Grid.Row="0" Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="14,9">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource Accent}" />
                    <TextBlock Text="Agnes" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Fg}" />
                    <TextBlock Text="simulated host" FontSize="11" Foreground="{StaticResource FgFaint}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Search across all open sessions -->
                <Button Grid.Column="1" HorizontalAlignment="Center" Padding="0" Background="Transparent" BorderThickness="0"
                        AutomationProperties.Name="Search across sessions">
                    <Border Background="{StaticResource PanelAlt}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                            CornerRadius="8" Padding="10,5" Width="360">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⌕" Foreground="{StaticResource FgFaint}" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Text="Search across all sessions…" Foreground="{StaticResource FgFaint}" FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel Width="420" Spacing="8">
                                <TextBox Text="{Binding GlobalSearchQuery, Mode=TwoWay}" Watermark="Search across all sessions…"
                                         Background="{StaticResource PanelAlt}" Foreground="{StaticResource Fg}"
                                         BorderBrush="{StaticResource Line}" CornerRadius="7" Padding="9,5" FontSize="12"
                                         AutomationProperties.Name="Search query across sessions" />
                                <TextBlock Text="No matches" Foreground="{StaticResource FgFaint}" FontSize="11"
                                           IsVisible="{Binding !HasGlobalResults}" />
                                <ItemsControl ItemsSource="{Binding GlobalResults}" MaxHeight="360">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding $parent[ItemsControl].DataContext.SelectGlobalHitCommand}"
                                                    CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                    Padding="7,5" CornerRadius="6" Cursor="Hand">
                                                <StackPanel Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding SessionTitle}" Foreground="{StaticResource Fg}"
                                                                   FontSize="11" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Kind}" Foreground="{StaticResource Good}" FontSize="10"
                                                                   FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Snippet}" Foreground="{StaticResource FgDim}" FontSize="11"
                                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <!-- Settings: accessibility + keyboard reference -->
                    <Button Content="⚙" Background="Transparent" Foreground="{StaticResource FgDim}"
                            BorderBrush="{StaticResource Line}" BorderThickness="1"
                            CornerRadius="7" Padding="10,5" FontSize="12" AutomationProperties.Name="Settings">
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <StackPanel Width="320" Spacing="10">
                                    <TextBlock Text="Accessibility" Foreground="{StaticResource Fg}" FontWeight="SemiBold" FontSize="12" />
                                    <CheckBox IsChecked="{Binding ReducedMotion, Mode=TwoWay}" Foreground="{StaticResource Fg}"
                                              Content="Reduce motion" AutomationProperties.Name="Reduce motion"
                                              ToolTip.Tip="Minimise non-essential animation" />
                                    <Border Height="1" Background="{StaticResource Line}" />
                                    <TextBlock Text="Keyboard" Foreground="{StaticResource Fg}" FontWeight="SemiBold" FontSize="12" />
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Ctrl+T  New tab · Ctrl+W  Close tab" Foreground="{StaticResource FgDim}" FontSize="11" />
                                        <TextBlock Text="Ctrl+Enter  Send · Alt+↑/↓  Prompt history" Foreground="{StaticResource FgDim}" FontSize="11" />
                                        <TextBlock Text="Ctrl+F  Search · F3/Shift+F3  Next/prev match" Foreground="{StaticResource FgDim}" FontSize="11" />
                                        <TextBlock Text="F8/F7  Next/prev prompt · Ctrl+F8/F7  Next/prev change" Foreground="{StaticResource FgDim}" FontSize="11" />
                                    </StackPanel>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button Background="Transparent" Foreground="{StaticResource FgDim}"
                            BorderBrush="{StaticResource Line}" BorderThickness="1"
                            CornerRadius="7" Padding="10,5" FontSize="12"
                            IsVisible="{Binding HasArchived}" AutomationProperties.Name="Reopen archived sessions">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="🗄" FontSize="12" />
                            <TextBlock Text="Archived" />
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout>
                                <ItemsControl ItemsSource="{Binding ArchivedSessions}" MaxWidth="340">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding $parent[ItemsControl].DataContext.ReopenArchivedCommand}"
                                                    CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                    Padding="8,6" CornerRadius="6" Cursor="Hand">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource Fg}" FontSize="12" />
                                                    <TextBlock Text="{Binding HostName}" Foreground="{StaticResource FgFaint}" FontSize="10" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button Command="{Binding NewTabCommand}"
                            Background="Transparent" Foreground="{StaticResource FgDim}"
                            BorderBrush="{StaticResource Line}" BorderThickness="1"
                            CornerRadius="7" Padding="10,5" FontSize="12" AutomationProperties.Name="New tab">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="+" FontSize="14" />
                            <TextBlock Text="New tab" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <dc:DockControl Grid.Row="1" Layout="{Binding Layout}" />
    </Grid>
</Window>
