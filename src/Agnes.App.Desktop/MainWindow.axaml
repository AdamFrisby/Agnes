<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dc="using:Dock.Avalonia.Controls"
        x:Class="Agnes.App.Desktop.MainWindow"
        Title="{Binding WindowTitle}" Width="1180" Height="760"
        MinWidth="720" MinHeight="480"
        Background="{DynamicResource Bg}"
        FontFamily="{StaticResource UiFont}">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+T" Command="{Binding NewTabCommand}" />
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseActiveTabCommand}" />
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding NextTabCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding PrevTabCommand}" />
        <KeyBinding Gesture="Ctrl+PageDown" Command="{Binding NextTabCommand}" />
        <KeyBinding Gesture="Ctrl+PageUp" Command="{Binding PrevTabCommand}" />
        <KeyBinding Gesture="Ctrl+D1" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="1" />
        <KeyBinding Gesture="Ctrl+D2" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="2" />
        <KeyBinding Gesture="Ctrl+D3" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="3" />
        <KeyBinding Gesture="Ctrl+D4" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="4" />
        <KeyBinding Gesture="Ctrl+D5" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="5" />
        <KeyBinding Gesture="Ctrl+D6" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="6" />
        <KeyBinding Gesture="Ctrl+D7" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="7" />
        <KeyBinding Gesture="Ctrl+D8" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="8" />
        <KeyBinding Gesture="Ctrl+D9" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="9" />
        <KeyBinding Gesture="Ctrl+K" Command="{Binding TogglePaletteCommand}" />
    </Window.KeyBindings>

    <!-- Native menu — shown in the macOS menu bar (inert on Windows/Linux, where the top bar serves). -->
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="File">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="New Tab" Gesture="Ctrl+T" Command="{Binding NewTabCommand}" />
                        <NativeMenuItem Header="Close Tab" Gesture="Ctrl+W" Command="{Binding CloseActiveTabCommand}" />
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
        </NativeMenu>
    </NativeMenu.Menu>

    <Window.Styles>
        <!-- Segmented selector buttons (e.g. the theme picker) -->
        <Style Selector="Button.seg">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="14,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.seg.on">
            <Setter Property="Background" Value="{DynamicResource Accent}" />
            <Setter Property="Foreground" Value="#1A1200" />
        </Style>
    </Window.Styles>

    <!-- Whole-UI zoom (accessibility / density) via a layout transform. The scaled tree is wrapped in a
         ScrollViewer so that when a large scale on a small window pushes content past the viewport, it can
         be scrolled to rather than being silently clipped. ScaleRoot's size is pinned to (client / scale)
         with a floor in code-behind (see MainWindow.axaml.cs), so content fills the window when it fits and
         scrolls when it doesn't. -->
    <!-- Scrollbars stay Disabled at 100% (content is pinned to fit exactly) and only switch to Auto when
         zoomed past 100%, so a child BringIntoView can never scroll the whole app at normal scale. -->
    <ScrollViewer x:Name="ScaleScroller"
                  HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{Binding FontScale}" ScaleY="{Binding FontScale}" />
        </LayoutTransformControl.LayoutTransform>
    <Grid x:Name="ScaleRoot" RowDefinitions="Auto,Auto,*">

        <!-- Top bar (fallback): LeftBar/RightBar are relocated into the Dock tab strip at runtime and this
             whole row is collapsed once that succeeds (see MainWindow.axaml.cs). -->
        <Border x:Name="TopBar" Grid.Row="0" Background="{DynamicResource Panel}"
                BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="14,9">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" x:Name="LeftBar" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Border Width="10" Height="10" CornerRadius="5" Background="{DynamicResource Accent}" VerticalAlignment="Center" />
                        <TextBlock Text="Agnes" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Search across all open sessions -->
                    <Button Padding="0" Background="Transparent" BorderThickness="0" VerticalAlignment="Center"
                            AutomationProperties.Name="Search across sessions">
                    <Border Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="8" Padding="10,5" Width="360">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⌕" Foreground="{DynamicResource FgFaint}" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Text="Search across all sessions…" Foreground="{DynamicResource FgFaint}" FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel Width="420" Spacing="8">
                                <!-- Auto-focus the real search box the moment the popover opens, so clicking
                                     the bar and typing is one motion, not two separate inputs (defect #9). -->
                                <TextBox Text="{Binding GlobalSearchQuery, Mode=TwoWay}" Watermark="Search across all sessions…"
                                         AttachedToVisualTree="OnGlobalSearchAttached"
                                         Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                         BorderBrush="{DynamicResource Line}" CornerRadius="7" Padding="9,5" FontSize="12"
                                         AutomationProperties.Name="Search query across sessions" />
                                <TextBlock Text="No matches" Foreground="{DynamicResource FgFaint}" FontSize="11"
                                           IsVisible="{Binding !HasGlobalResults}" />
                                <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding GlobalResults}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding $parent[ItemsControl].DataContext.SelectGlobalHitCommand}"
                                                    CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                    Padding="7,5" CornerRadius="6" Cursor="Hand">
                                                <StackPanel Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding SessionTitle}" Foreground="{DynamicResource Fg}"
                                                                   FontSize="11" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Kind}" Foreground="{DynamicResource Good}" FontSize="10"
                                                                   FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Snippet}" Foreground="{DynamicResource FgDim}" FontSize="11"
                                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" x:Name="RightBar" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <!-- Update available -->
                    <Button Command="{Binding OpenUpdateCommand}" IsVisible="{Binding UpdateAvailable}"
                            Background="{DynamicResource Accent}" Foreground="#1A1200"
                            BorderThickness="0" CornerRadius="7" Padding="10,5" FontSize="12" FontWeight="SemiBold"
                            AutomationProperties.Name="Download update"
                            ToolTip.Tip="A newer version of Agnes is available">
                        <TextBlock Text="{Binding UpdateVersion, StringFormat='⬆ Update {0}'}" />
                    </Button>
                    <!-- Inbox: completed background runs -->
                    <Button Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="10,5" FontSize="12"
                            IsVisible="{Binding HasInbox}" AutomationProperties.Name="Background run inbox">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="🗓 Inbox" VerticalAlignment="Center" />
                            <Border Background="{DynamicResource Accent}" CornerRadius="8" Padding="5,1" MinWidth="16" VerticalAlignment="Center">
                                <TextBlock Text="{Binding InboxCount}" Foreground="#1A1200" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <ScrollViewer MinWidth="360" MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Inbox}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,6" Margin="0,2" CornerRadius="6" Background="{DynamicResource PanelAlt}">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Fg}" FontSize="12" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource FgDim}" FontSize="11" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Sessions switcher: state of every open session + attention -->
                    <Button Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="7" Padding="10,5" FontSize="12" AutomationProperties.Name="Sessions">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="Sessions" VerticalAlignment="Center" />
                            <Border Background="{DynamicResource Accent}" CornerRadius="8" Padding="5,1" MinWidth="16" VerticalAlignment="Center"
                                    IsVisible="{Binding HasAttention}">
                                <TextBlock Text="{Binding AttentionCount}" Foreground="#1A1200" FontSize="10"
                                           FontWeight="SemiBold" HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <ScrollViewer MinWidth="320" MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding OpenSessions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding $parent[ItemsControl].DataContext.ActivateSessionCommand}"
                                                    CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                    Padding="8,6" CornerRadius="6" Cursor="Hand">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                    <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                                                            Background="{DynamicResource Accent}" IsVisible="{Binding NeedsAttention}" />
                                                    <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                                                            Background="{DynamicResource FgFaint}" IsVisible="{Binding !NeedsAttention}" />
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Fg}" FontSize="12" />
                                                        <TextBlock Text="{Binding HostName}" Foreground="{DynamicResource FgFaint}" FontSize="10" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <!-- Unread badge (sessions/05): activity you haven't looked at yet. -->
                                                        <Border Width="7" Height="7" CornerRadius="4" VerticalAlignment="Center"
                                                                Background="{DynamicResource Accent}" IsVisible="{Binding IsUnread}"
                                                                ToolTip.Tip="Unread" />
                                                        <TextBlock Text="{Binding ActivityText}" Foreground="{DynamicResource FgDim}"
                                                                   FontSize="10" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Search: opens a first-class tab searching every recorded session's transcript -->
                    <Button Content="🔍" Command="{Binding OpenSearchCommand}" Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="7" Padding="10,5" FontSize="12" AutomationProperties.Name="Search history" />

                    <!-- Settings: opens a first-class, searchable Settings tab -->
                    <Button Content="⚙" Command="{Binding OpenSettingsCommand}" Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="7" Padding="10,5" FontSize="12" AutomationProperties.Name="Settings" />
                    <Button Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="7" Padding="10,5" FontSize="12"
                            IsVisible="{Binding HasArchived}" AutomationProperties.Name="Reopen archived sessions">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="🗄" FontSize="12" />
                            <TextBlock Text="Archived" />
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout>
                                <ScrollViewer MaxWidth="340" MaxHeight="380" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ArchivedSessions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding $parent[ItemsControl].DataContext.ReopenArchivedCommand}"
                                                    CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                    Padding="8,6" CornerRadius="6" Cursor="Hand">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Fg}" FontSize="12" />
                                                    <TextBlock Text="{Binding HostName}" Foreground="{DynamicResource FgFaint}" FontSize="10" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button Command="{Binding NewTabCommand}"
                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="7" Padding="10,5" FontSize="12" AutomationProperties.Name="New tab">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="+" FontSize="14" />
                            <TextBlock Text="New tab" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- First-run nudge: link a GitHub account so sandboxed agents can clone/push private repos.
             Its own row (Auto → 0 when hidden) so it sits above the tab strip instead of overlapping it,
             with a solid background so it's readable. -->
        <Border Grid.Row="1" IsVisible="{Binding ShowGitHubLinkPrompt}"
                Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Accent}" BorderThickness="0,0,0,2" Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="🔗" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Link a GitHub account?" Foreground="{DynamicResource Fg}" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock Text="Sandboxed agents need it to clone or push private repositories. You can also do this later in Settings › GitHub."
                               Foreground="{DynamicResource FgDim}" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="2" Content="Link GitHub" Command="{Binding LinkGitHubNowCommand}" VerticalAlignment="Center"
                        Background="{DynamicResource Accent}" Foreground="#1A1200" CornerRadius="7" Padding="12,5" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" />
                <Button Grid.Column="3" Content="Later" Command="{Binding DismissGitHubLinkPromptCommand}" VerticalAlignment="Center"
                        Background="Transparent" Foreground="{DynamicResource FgDim}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                        CornerRadius="7" Padding="12,5" FontSize="12" Margin="8,0,0,0" />
            </Grid>
        </Border>

        <dc:DockControl x:Name="DockRoot" Grid.Row="2" Layout="{Binding Layout}" />

        <!-- Command palette (Ctrl+K): jump to a session or run an action -->
        <Border Grid.Row="0" Grid.RowSpan="3" ZIndex="100" IsVisible="{Binding IsPaletteOpen}"
                Background="#88000000">
            <Border Width="540" MaxHeight="460" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,90,0,0"
                    Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                    CornerRadius="12" Padding="10" BoxShadow="0 20 60 -20 #000000">
                <StackPanel Spacing="8">
                    <TextBox x:Name="PaletteBox" Text="{Binding PaletteQuery, Mode=TwoWay}"
                             Watermark="Jump to a session or action…" FontSize="14"
                             Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Line}" CornerRadius="8" Padding="10,8">
                        <TextBox.KeyBindings>
                            <!-- Focus stays in the box for typing; Up/Down move the highlighted row and Enter
                                 runs it, so the palette is fully keyboard-navigable (defect #9). -->
                            <KeyBinding Gesture="Down" Command="{Binding MovePaletteSelectionCommand}" CommandParameter="down" />
                            <KeyBinding Gesture="Up" Command="{Binding MovePaletteSelectionCommand}" CommandParameter="up" />
                            <KeyBinding Gesture="Enter" Command="{Binding RunTopPaletteItemCommand}" />
                            <KeyBinding Gesture="Escape" Command="{Binding ClosePaletteCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                    <ListBox MaxHeight="380" ItemsSource="{Binding PaletteItems}"
                             SelectedIndex="{Binding SelectedPaletteIndex, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="CornerRadius" Value="7" />
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding $parent[ItemsControl].DataContext.RunPaletteItemCommand}"
                                        CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                        Padding="10,7" CornerRadius="7" Cursor="Hand">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{DynamicResource Fg}" FontSize="13" />
                                        <TextBlock Grid.Column="1" Text="{Binding Hint}" Foreground="{DynamicResource FgFaint}" FontSize="11" VerticalAlignment="Center" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Border>

        <!-- Fork session: choose a target folder (copy of the working folder) and whether to CoW-clone the sandbox -->
        <Border Grid.Row="0" Grid.RowSpan="3" ZIndex="110" IsVisible="{Binding IsForkPromptOpen}"
                Background="#88000000">
            <Border Width="540" MaxHeight="460" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                    CornerRadius="12" Padding="20" BoxShadow="0 20 60 -20 #000000"
                    DataContext="{Binding ForkPrompt}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Fork session" Foreground="{DynamicResource Fg}" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Copies the working folder to a new location and opens a fresh session there."
                                   Foreground="{DynamicResource FgDim}" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="From" Foreground="{DynamicResource FgFaint}" FontSize="11" />
                        <TextBlock Text="{Binding SourceDirectory}" Foreground="{DynamicResource FgDim}" FontSize="12"
                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Copy to" Foreground="{DynamicResource FgFaint}" FontSize="11" />
                        <TextBox Text="{Binding TargetDirectory, Mode=TwoWay}" FontSize="13"
                                 Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                 BorderBrush="{DynamicResource Line}" CornerRadius="8" Padding="10,8" />
                    </StackPanel>

                    <CheckBox IsChecked="{Binding CopySandbox, Mode=TwoWay}" IsVisible="{Binding CanCopySandbox}"
                              Foreground="{DynamicResource Fg}" FontSize="12">
                        <StackPanel Spacing="1">
                            <TextBlock Text="Copy the sandbox (copy-on-write)" Foreground="{DynamicResource Fg}" FontSize="12" />
                            <TextBlock Text="Clones the VM's installed tooling/state; fast on ZFS. Otherwise a fresh sandbox is created."
                                       Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap" />
                        </StackPanel>
                    </CheckBox>

                    <TextBlock Text="{Binding ErrorText}" IsVisible="{Binding HasError}" Foreground="#E5484D"
                               FontSize="12" TextWrapping="Wrap" />

                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <TextBlock Grid.Column="0" Text="Working…" IsVisible="{Binding Busy}" Foreground="{DynamicResource FgDim}"
                                   FontSize="12" VerticalAlignment="Center" />
                        <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding !Busy}"
                                Background="Transparent" Foreground="{DynamicResource FgDim}" BorderBrush="{DynamicResource Line}"
                                BorderThickness="1" CornerRadius="7" Padding="14,6" FontSize="12" Margin="8,0,0,0" />
                        <Button Grid.Column="3" Content="Fork" Command="{Binding ConfirmCommand}" IsEnabled="{Binding !Busy}"
                                Background="{DynamicResource Accent}" Foreground="#1A1200" CornerRadius="7" Padding="16,6"
                                FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
    </LayoutTransformControl>
    </ScrollViewer>
</Window>
