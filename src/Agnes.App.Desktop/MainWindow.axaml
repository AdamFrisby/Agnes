<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dc="using:Dock.Avalonia.Controls"
        x:Class="Agnes.App.Desktop.MainWindow"
        Title="{Binding WindowTitle}" Width="1180" Height="760"
        MinWidth="720" MinHeight="480"
        Background="{DynamicResource Bg}"
        FontFamily="{StaticResource UiFont}">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+T" Command="{Binding NewTabCommand}" />
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseActiveTabCommand}" />
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding NextTabCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding PrevTabCommand}" />
        <KeyBinding Gesture="Ctrl+PageDown" Command="{Binding NextTabCommand}" />
        <KeyBinding Gesture="Ctrl+PageUp" Command="{Binding PrevTabCommand}" />
        <KeyBinding Gesture="Ctrl+D1" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="1" />
        <KeyBinding Gesture="Ctrl+D2" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="2" />
        <KeyBinding Gesture="Ctrl+D3" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="3" />
        <KeyBinding Gesture="Ctrl+D4" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="4" />
        <KeyBinding Gesture="Ctrl+D5" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="5" />
        <KeyBinding Gesture="Ctrl+D6" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="6" />
        <KeyBinding Gesture="Ctrl+D7" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="7" />
        <KeyBinding Gesture="Ctrl+D8" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="8" />
        <KeyBinding Gesture="Ctrl+D9" Command="{Binding ActivateTabByIndexCommand}" CommandParameter="9" />
        <KeyBinding Gesture="Ctrl+K" Command="{Binding TogglePaletteCommand}" />
    </Window.KeyBindings>

    <!-- Native menu — shown in the macOS menu bar (inert on Windows/Linux, where the top bar serves). -->
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="File">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="New Tab" Gesture="Ctrl+T" Command="{Binding NewTabCommand}" />
                        <NativeMenuItem Header="Close Tab" Gesture="Ctrl+W" Command="{Binding CloseActiveTabCommand}" />
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
        </NativeMenu>
    </NativeMenu.Menu>

    <Window.Styles>
        <!-- Segmented selector buttons (e.g. the theme picker) -->
        <Style Selector="Button.seg">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="14,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.seg.on">
            <Setter Property="Background" Value="{DynamicResource Accent}" />
            <Setter Property="Foreground" Value="#1A1200" />
        </Style>
    </Window.Styles>

    <!-- Whole-UI zoom (accessibility / density) via a layout transform. -->
    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{Binding FontScale}" ScaleY="{Binding FontScale}" />
        </LayoutTransformControl.LayoutTransform>
    <Grid RowDefinitions="Auto,*">

        <!-- Top bar: title + new-tab (browser-style) -->
        <Border Grid.Row="0" Background="{DynamicResource Panel}"
                BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="14,9">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="10" Height="10" CornerRadius="5" Background="{DynamicResource Accent}" VerticalAlignment="Center" />
                    <TextBlock Text="Agnes" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" VerticalAlignment="Center" />
                    <TextBlock Text="simulated host" FontSize="11" Foreground="{DynamicResource FgFaint}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Search across all open sessions -->
                <Button Grid.Column="1" HorizontalAlignment="Center" Padding="0" Background="Transparent" BorderThickness="0"
                        AutomationProperties.Name="Search across sessions">
                    <Border Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="8" Padding="10,5" Width="360">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⌕" Foreground="{DynamicResource FgFaint}" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Text="Search across all sessions…" Foreground="{DynamicResource FgFaint}" FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel Width="420" Spacing="8">
                                <TextBox Text="{Binding GlobalSearchQuery, Mode=TwoWay}" Watermark="Search across all sessions…"
                                         Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                         BorderBrush="{DynamicResource Line}" CornerRadius="7" Padding="9,5" FontSize="12"
                                         AutomationProperties.Name="Search query across sessions" />
                                <TextBlock Text="No matches" Foreground="{DynamicResource FgFaint}" FontSize="11"
                                           IsVisible="{Binding !HasGlobalResults}" />
                                <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding GlobalResults}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding $parent[ItemsControl].DataContext.SelectGlobalHitCommand}"
                                                    CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                    Padding="7,5" CornerRadius="6" Cursor="Hand">
                                                <StackPanel Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding SessionTitle}" Foreground="{DynamicResource Fg}"
                                                                   FontSize="11" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Kind}" Foreground="{DynamicResource Good}" FontSize="10"
                                                                   FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Snippet}" Foreground="{DynamicResource FgDim}" FontSize="11"
                                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <!-- Update available -->
                    <Button Command="{Binding OpenUpdateCommand}" IsVisible="{Binding UpdateAvailable}"
                            Background="{DynamicResource Accent}" Foreground="#1A1200"
                            BorderThickness="0" CornerRadius="7" Padding="10,5" FontSize="12" FontWeight="SemiBold"
                            AutomationProperties.Name="Download update"
                            ToolTip.Tip="A newer version of Agnes is available">
                        <TextBlock Text="{Binding UpdateVersion, StringFormat='⬆ Update {0}'}" />
                    </Button>
                    <!-- Inbox: completed background runs -->
                    <Button Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="10,5" FontSize="12"
                            IsVisible="{Binding HasInbox}" AutomationProperties.Name="Background run inbox">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="🗓 Inbox" VerticalAlignment="Center" />
                            <Border Background="{DynamicResource Accent}" CornerRadius="8" Padding="5,1" MinWidth="16" VerticalAlignment="Center">
                                <TextBlock Text="{Binding InboxCount}" Foreground="#1A1200" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <ScrollViewer MinWidth="360" MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Inbox}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,6" Margin="0,2" CornerRadius="6" Background="{DynamicResource PanelAlt}">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Fg}" FontSize="12" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource FgDim}" FontSize="11" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Sessions switcher: state of every open session + attention -->
                    <Button Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="7" Padding="10,5" FontSize="12" AutomationProperties.Name="Sessions">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="Sessions" VerticalAlignment="Center" />
                            <Border Background="{DynamicResource Accent}" CornerRadius="8" Padding="5,1" MinWidth="16" VerticalAlignment="Center"
                                    IsVisible="{Binding HasAttention}">
                                <TextBlock Text="{Binding AttentionCount}" Foreground="#1A1200" FontSize="10"
                                           FontWeight="SemiBold" HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <ScrollViewer MinWidth="320" MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding OpenSessions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding $parent[ItemsControl].DataContext.ActivateSessionCommand}"
                                                    CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                    Padding="8,6" CornerRadius="6" Cursor="Hand">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                    <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                                                            Background="{DynamicResource Accent}" IsVisible="{Binding NeedsAttention}" />
                                                    <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                                                            Background="{DynamicResource FgFaint}" IsVisible="{Binding !NeedsAttention}" />
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Fg}" FontSize="12" />
                                                        <TextBlock Text="{Binding HostName}" Foreground="{DynamicResource FgFaint}" FontSize="10" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding ActivityText}" Foreground="{DynamicResource FgDim}"
                                                               FontSize="10" VerticalAlignment="Center" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Settings: accessibility + keyboard reference -->
                    <Button Content="⚙" Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="7" Padding="10,5" FontSize="12" AutomationProperties.Name="Settings">
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <StackPanel Width="320" Spacing="10">
                                    <TextBlock Text="Appearance" Foreground="{DynamicResource Fg}" FontWeight="SemiBold" FontSize="12" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Content="System" Command="{Binding SetThemeCommand}" CommandParameter="System"
                                                Classes.on="{Binding IsSystemTheme}" Classes="seg" />
                                        <Button Content="Light" Command="{Binding SetThemeCommand}" CommandParameter="Light"
                                                Classes.on="{Binding IsLightTheme}" Classes="seg" />
                                        <Button Content="Dark" Command="{Binding SetThemeCommand}" CommandParameter="Dark"
                                                Classes.on="{Binding IsDarkTheme}" Classes="seg" />
                                    </StackPanel>
                                    <TextBlock Text="UI scale" Foreground="{DynamicResource FgDim}" FontSize="11" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Content="Small" Command="{Binding SetScaleCommand}" CommandParameter="small"
                                                Classes.on="{Binding IsScaleSmall}" Classes="seg" />
                                        <Button Content="Default" Command="{Binding SetScaleCommand}" CommandParameter="default"
                                                Classes.on="{Binding IsScaleDefault}" Classes="seg" />
                                        <Button Content="Large" Command="{Binding SetScaleCommand}" CommandParameter="large"
                                                Classes.on="{Binding IsScaleLarge}" Classes="seg" />
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource Line}" />
                                    <TextBlock Text="Accessibility" Foreground="{DynamicResource Fg}" FontWeight="SemiBold" FontSize="12" />
                                    <CheckBox IsChecked="{Binding ReducedMotion, Mode=TwoWay}" Foreground="{DynamicResource Fg}"
                                              Content="Reduce motion" AutomationProperties.Name="Reduce motion"
                                              ToolTip.Tip="Minimise non-essential animation" />
                                    <Border Height="1" Background="{DynamicResource Line}" />
                                    <TextBlock Text="Keyboard" Foreground="{DynamicResource Fg}" FontWeight="SemiBold" FontSize="12" />
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Ctrl+T  New tab · Ctrl+W  Close tab · Ctrl+Tab  Next tab" Foreground="{DynamicResource FgDim}" FontSize="11" />
                                        <TextBlock Text="Ctrl+Enter  Send · Alt+↑/↓  Prompt history" Foreground="{DynamicResource FgDim}" FontSize="11" />
                                        <TextBlock Text="Ctrl+F  Search · F3/Shift+F3  Next/prev match" Foreground="{DynamicResource FgDim}" FontSize="11" />
                                        <TextBlock Text="F8/F7  Next/prev prompt · Ctrl+F8/F7  Next/prev change" Foreground="{DynamicResource FgDim}" FontSize="11" />
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource Line}" />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="Paired devices" Foreground="{DynamicResource Fg}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="Refresh" Command="{Binding LoadDevicesCommand}" Classes="seg" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Devices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Fg}" FontSize="12" />
                                                        <TextBlock Text="{Binding PairedAt, StringFormat='paired {0:yyyy-MM-dd}'}" Foreground="{DynamicResource FgFaint}" FontSize="10" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Revoke" FontSize="11" Padding="9,3"
                                                            Background="Transparent" Foreground="#E5484D"
                                                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6"
                                                            Command="{Binding $parent[ItemsControl].DataContext.RevokeDeviceCommand}"
                                                            CommandParameter="{Binding Id}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="{Binding DevicesStatus}" Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap" />

                                    <Border Height="1" Background="{DynamicResource Line}" />

                                    <!-- MCP servers: configured here, run on the host or inside the sandbox -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="MCP servers" Foreground="{DynamicResource Fg}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="Refresh" Command="{Binding LoadMcpServersCommand}" Classes="seg" />
                                    </Grid>

                                    <!-- gating posture for the MCP tools Agnes forwards -->
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Tools" Foreground="{DynamicResource FgDim}" FontSize="11" VerticalAlignment="Center" />
                                        <Button Content="Ask first" Command="{Binding SetMcpApprovalCommand}" CommandParameter="Ask"
                                                Classes.on="{Binding McpApprovalAsk}" Classes="seg"
                                                ToolTip.Tip="Attended sessions approve each MCP tool as usual; autonomous sessions don't get host MCP servers forwarded" />
                                        <Button Content="Trust" Command="{Binding SetMcpApprovalCommand}" CommandParameter="Trust"
                                                Classes.on="{Binding McpApprovalTrust}" Classes="seg"
                                                ToolTip.Tip="Also forward host MCP servers to autonomous sessions (calls are still recorded in the MCP audit trail)" />
                                    </StackPanel>

                                    <ItemsControl ItemsSource="{Binding McpServers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,3" ColumnSpacing="6">
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Fg}" FontSize="12" />
                                                        <TextBlock Foreground="{DynamicResource FgFaint}" FontSize="10">
                                                            <Run Text="{Binding Transport}" /><Run Text=" · run at " /><Run Text="{Binding RunAt}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" FontSize="11" Padding="9,3" Classes="seg"
                                                            Classes.on="{Binding Enabled}"
                                                            Command="{Binding $parent[ItemsControl].DataContext.ToggleMcpServerCommand}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip.Tip="Enable or disable this server">
                                                        <Panel>
                                                            <TextBlock Text="Enabled" IsVisible="{Binding Enabled}" />
                                                            <TextBlock Text="Disabled" IsVisible="{Binding !Enabled}" />
                                                        </Panel>
                                                    </Button>
                                                    <Button Grid.Column="2" Content="Remove" FontSize="11" Padding="9,3"
                                                            Background="Transparent" Foreground="#E5484D"
                                                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6"
                                                            Command="{Binding $parent[ItemsControl].DataContext.RemoveMcpServerCommand}"
                                                            CommandParameter="{Binding Id}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- add a server -->
                                    <Border Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                                            CornerRadius="8" Padding="9" Margin="0,2,0,0">
                                        <StackPanel Spacing="6">
                                            <TextBox Text="{Binding NewMcpName, Mode=TwoWay}" Watermark="Server name"
                                                     FontSize="12" Padding="8,5" CornerRadius="6" />
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Run at" Foreground="{DynamicResource FgDim}" FontSize="11" VerticalAlignment="Center" />
                                                <Button Content="Host" Command="{Binding SetNewMcpRunAtCommand}" CommandParameter="host"
                                                        Classes.on="{Binding NewMcpRunAtHost}" Classes="seg" />
                                                <Button Content="Sandbox" Command="{Binding SetNewMcpRunAtCommand}" CommandParameter="sandbox"
                                                        Classes.on="{Binding NewMcpRunAtSandbox}" Classes="seg" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Transport" Foreground="{DynamicResource FgDim}" FontSize="11" VerticalAlignment="Center" />
                                                <Button Content="stdio" Command="{Binding SetNewMcpTransportCommand}" CommandParameter="stdio"
                                                        Classes.on="{Binding NewMcpIsStdio}" Classes="seg" />
                                                <Button Content="http" Command="{Binding SetNewMcpTransportCommand}" CommandParameter="http"
                                                        Classes.on="{Binding NewMcpIsHttp}" Classes="seg" />
                                            </StackPanel>
                                            <StackPanel Spacing="6" IsVisible="{Binding NewMcpIsStdio}">
                                                <TextBox Text="{Binding NewMcpCommand, Mode=TwoWay}" Watermark="command (e.g. npx)"
                                                         FontSize="12" Padding="8,5" CornerRadius="6" FontFamily="{StaticResource MonoFont}" />
                                                <TextBox Text="{Binding NewMcpArgs, Mode=TwoWay}" Watermark="args (space-separated)"
                                                         FontSize="12" Padding="8,5" CornerRadius="6" FontFamily="{StaticResource MonoFont}" />
                                            </StackPanel>
                                            <TextBox IsVisible="{Binding NewMcpIsHttp}" Text="{Binding NewMcpUrl, Mode=TwoWay}"
                                                     Watermark="https://server/mcp" FontSize="12" Padding="8,5" CornerRadius="6"
                                                     FontFamily="{StaticResource MonoFont}" />
                                            <Button Content="Add server" Command="{Binding AddMcpServerCommand}" HorizontalAlignment="Left"
                                                    Classes="seg" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="{Binding McpStatus}" Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="7" Padding="10,5" FontSize="12"
                            IsVisible="{Binding HasArchived}" AutomationProperties.Name="Reopen archived sessions">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="🗄" FontSize="12" />
                            <TextBlock Text="Archived" />
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout>
                                <ScrollViewer MaxWidth="340" MaxHeight="380" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ArchivedSessions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding $parent[ItemsControl].DataContext.ReopenArchivedCommand}"
                                                    CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                    Padding="8,6" CornerRadius="6" Cursor="Hand">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Fg}" FontSize="12" />
                                                    <TextBlock Text="{Binding HostName}" Foreground="{DynamicResource FgFaint}" FontSize="10" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button Command="{Binding NewTabCommand}"
                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="7" Padding="10,5" FontSize="12" AutomationProperties.Name="New tab">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="+" FontSize="14" />
                            <TextBlock Text="New tab" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <dc:DockControl Grid.Row="1" Layout="{Binding Layout}" />

        <!-- Command palette (Ctrl+K): jump to a session or run an action -->
        <Border Grid.Row="0" Grid.RowSpan="2" ZIndex="100" IsVisible="{Binding IsPaletteOpen}"
                Background="#88000000">
            <Border Width="540" MaxHeight="460" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,90,0,0"
                    Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                    CornerRadius="12" Padding="10" BoxShadow="0 20 60 -20 #000000">
                <StackPanel Spacing="8">
                    <TextBox x:Name="PaletteBox" Text="{Binding PaletteQuery, Mode=TwoWay}"
                             Watermark="Jump to a session or action…" FontSize="14"
                             Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Line}" CornerRadius="8" Padding="10,8">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding RunTopPaletteItemCommand}" />
                            <KeyBinding Gesture="Escape" Command="{Binding ClosePaletteCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                    <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PaletteItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding $parent[ItemsControl].DataContext.RunPaletteItemCommand}"
                                            CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                            Padding="10,7" CornerRadius="7" Cursor="Hand">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{DynamicResource Fg}" FontSize="13" />
                                            <TextBlock Grid.Column="1" Text="{Binding Hint}" Foreground="{DynamicResource FgFaint}" FontSize="11" VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
    </LayoutTransformControl>
</Window>
