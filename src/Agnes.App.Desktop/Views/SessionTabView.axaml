<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tr="using:Agnes.Ui.Core.Transcript"
             xmlns:vm="using:Agnes.Ui.Core.ViewModels"
             xmlns:conv="using:Avalonia.Data.Converters"
             xmlns:ctl="using:Agnes.App.Desktop.Controls"
             xmlns:mdxaml="https://github.com/whistyun/Markdown.Avalonia"
             x:Class="Agnes.App.Desktop.Views.SessionTabView"
             Background="{DynamicResource Bg}"
             FontFamily="{StaticResource UiFont}"
             DragDrop.AllowDrop="True">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+F" Command="{Binding Session.OpenSearchCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding Session.CloseSearchCommand}" />
        <KeyBinding Gesture="F3" Command="{Binding Session.NextMatchCommand}" />
        <KeyBinding Gesture="Shift+F3" Command="{Binding Session.PrevMatchCommand}" />
        <KeyBinding Gesture="F7" Command="{Binding Session.PrevPromptCommand}" />
        <KeyBinding Gesture="F8" Command="{Binding Session.NextPromptCommand}" />
        <KeyBinding Gesture="Ctrl+F8" Command="{Binding Session.NextChangeCommand}" />
        <KeyBinding Gesture="Ctrl+F7" Command="{Binding Session.PrevChangeCommand}" />
    </UserControl.KeyBindings>

    <UserControl.Styles>
        <Style Selector="Border.user">
            <Setter Property="Background" Value="{DynamicResource UserBubble}" />
        </Style>
        <Style Selector="TextBlock.thought">
            <Setter Property="Foreground" Value="{DynamicResource FgFaint}" />
            <Setter Property="FontStyle" Value="Italic" />
        </Style>
        <!-- Pulsing dot for the "Thinking…" indicator. -->
        <Style Selector="Border.pulse">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="INFINITE">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.35" /></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.35" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <!-- Per-message "⋯" actions: hidden until the pointer is over the message OR keyboard focus is
             within it (Opacity keeps layout stable). Touch/mouse users also get the same actions via the
             bubble's right-click / long-press ContextFlyout, so the menu is reachable without hover. -->
        <Style Selector="Border.msg Button.rowmenu">
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="Border.msg:pointerover Button.rowmenu">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Border.msg:focus-within Button.rowmenu">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <!-- Compact tool rows are chromeless; a faint hover fill keeps them discoverable as clickable. -->
        <Style Selector="Button.tool:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Panel}" />
        </Style>
        <Style Selector="Border.dot">
            <Setter Property="Background" Value="{DynamicResource FgFaint}" />
        </Style>
        <Style Selector="Border.dot.on">
            <Setter Property="Background" Value="{DynamicResource Good}" />
        </Style>
        <!-- activity chip -->
        <Style Selector="Border.chip">
            <Setter Property="Background" Value="{DynamicResource PanelAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Line}" />
        </Style>
        <Style Selector="Border.chip.attention">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>
        <Style Selector="Border.chip TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
        </Style>
        <Style Selector="Border.chip.attention TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        </Style>
        <!-- agent-tree node selection -->
        <Style Selector="TreeView Button TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        </Style>
        <Style Selector="Button.sel TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <!-- agent picker cards: accent border when chosen, dimmed when unavailable -->
        <Style Selector="Button.agent.sel">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
            <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
        </Style>
        <Style Selector="Button.agent:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="TreeViewItem">
            <Setter Property="IsExpanded" Value="True" />
        </Style>
        <!-- diff rows -->
        <Style Selector="Border.add">
            <Setter Property="Background" Value="{DynamicResource DiffAddBg}" />
        </Style>
        <Style Selector="Border.del">
            <Setter Property="Background" Value="{DynamicResource DiffDelBg}" />
        </Style>
        <Style Selector="Border.hunk">
            <Setter Property="Background" Value="{DynamicResource HunkBg}" />
        </Style>
        <Style Selector="Border.hunk TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource HunkFg}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Per-tab status bar -->
        <Border Grid.Row="0" IsVisible="{Binding ShowStatusBar}" Background="{DynamicResource Panel}"
                BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="16,7">
            <StackPanel Spacing="0">
                <!-- Left cluster is a flexible, clipped column so long host/agent names or many tags can
                     never push the action buttons (right, Auto) off-screen; the metadata yields first. -->
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                                HorizontalAlignment="Left" ClipToBounds="True">
                        <Border Classes="dot" Classes.on="{Binding IsConnected}" Width="8" Height="8"
                                CornerRadius="4" VerticalAlignment="Center" />
                        <TextBlock Text="★" Foreground="{DynamicResource Accent}" FontSize="12" VerticalAlignment="Center"
                                   IsVisible="{Binding Pinned}" ToolTip.Tip="Pinned" />
                        <TextBlock Text="{Binding HostName}" Foreground="{DynamicResource Fg}" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" MaxWidth="240" TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{Binding HostName}" />
                        <TextBlock Text="·" Foreground="{DynamicResource FgFaint}" IsVisible="{Binding IsLive}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding AgentName}" Foreground="{DynamicResource FgDim}" FontSize="12" IsVisible="{Binding IsLive}"
                                   VerticalAlignment="Center" MaxWidth="200" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding ConnectionText}" Foreground="{DynamicResource FgFaint}" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center" />
                        <Border Classes="chip" Classes.attention="{Binding NeedsAttention}" IsVisible="{Binding IsLive}"
                                BorderThickness="1" CornerRadius="9" Padding="8,2" VerticalAlignment="Center" Margin="2,0,0,0">
                            <TextBlock Text="{Binding ActivityText}" FontSize="10" FontWeight="SemiBold" />
                        </Border>
                        <!-- tag chips -->
                        <ItemsControl ItemsSource="{Binding Tags}" IsVisible="{Binding HasTags}" Margin="4,0,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="4" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Line}"
                                            BorderThickness="1" CornerRadius="10" Padding="8,1">
                                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource FgDim}" FontSize="10" />
                                            <Button Content="✕" Command="{Binding $parent[ItemsControl].DataContext.RemoveTagCommand}"
                                                    CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource FgFaint}"
                                                    BorderThickness="0" Padding="0" FontSize="9" Cursor="Hand"
                                                    AutomationProperties.Name="Remove tag" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button Command="{Binding Session.ToggleToolsCommand}" IsVisible="{Binding Session.HasTools}"
                                Content="Tool output" Background="Transparent" Foreground="{DynamicResource FgDim}"
                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6" Padding="9,3" FontSize="11"
                                ToolTip.Tip="Collapse / expand all tool output" AutomationProperties.Name="Toggle all tool output" />
                        <Button Command="{Binding Session.ToggleLeftCommand}" IsVisible="{Binding Session.HasSidebarContent}"
                                Content="Panels" Background="Transparent" Foreground="{DynamicResource FgDim}"
                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6" Padding="9,3" FontSize="11"
                                AutomationProperties.Name="Toggle side panels" />
                        <Button Command="{Binding Session.ToggleInspectorCommand}" IsVisible="{Binding IsLive}"
                                Content="Event log" Background="Transparent" Foreground="{DynamicResource FgDim}"
                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6" Padding="9,3" FontSize="11"
                                ToolTip.Tip="Show the raw event log" AutomationProperties.Name="Toggle raw event log" />
                        <!-- real context-window usage the agent reported (bar only when the window is known) -->
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                    IsVisible="{Binding Usage.HasAnyContext, FallbackValue=false}"
                                    ToolTip.Tip="Context tokens used (reported by the agent)">
                            <TextBlock Text="ctx" Foreground="{DynamicResource FgFaint}" FontSize="10" VerticalAlignment="Center" />
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding Usage.ContextPercent, FallbackValue=0}"
                                         Width="70" Height="6" VerticalAlignment="Center"
                                         IsVisible="{Binding Usage.HasContext, FallbackValue=false}"
                                         Foreground="{DynamicResource Accent}" Background="{DynamicResource PanelAlt}" />
                            <TextBlock Text="{Binding Usage.ContextText}" Foreground="{DynamicResource FgDim}" FontSize="10"
                                       VerticalAlignment="Center" FontFamily="{StaticResource MonoFont}" />
                        </StackPanel>
                        <TextBlock Text="{Binding UsageSummary}" Foreground="{DynamicResource FgDim}" FontSize="11"
                                   VerticalAlignment="Center" FontFamily="{StaticResource MonoFont}"
                                   IsVisible="{Binding UsageSummary, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                        <!-- Autonomous: agent runs tools without asking. Clickable so it isn't just a passive
                             badge — the flyout explains it and surfaces the live lever (switch the agent's
                             mode to one that pauses for approval, or stop the current turn). Defect #3. -->
                        <Button IsVisible="{Binding Session.IsAutonomous}" Background="{DynamicResource AccentSoft}"
                                BorderBrush="{DynamicResource Accent}" BorderThickness="1" CornerRadius="6" Padding="9,3"
                                VerticalAlignment="Center" AutomationProperties.Name="Autonomy"
                                ToolTip.Tip="This session runs tool calls without asking. Click to change how it asks.">
                            <TextBlock Text="⚡ autonomous" Foreground="{DynamicResource Accent}" FontSize="11" FontWeight="SemiBold" />
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <StackPanel Width="300" Spacing="10" DataContext="{Binding Session}">
                                        <TextBlock Text="Running autonomously" Foreground="{DynamicResource Fg}"
                                                   FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="The agent runs tool calls without asking for approval."
                                                   Foreground="{DynamicResource FgDim}" FontSize="12" TextWrapping="Wrap" />
                                        <!-- Live lever: switch the agent to a mode that pauses for approval. -->
                                        <StackPanel Spacing="6" IsVisible="{Binding HasModes}">
                                            <TextBlock Text="Switch mode (takes effect immediately)"
                                                       Foreground="{DynamicResource FgDim}" FontSize="11" />
                                            <ItemsControl ItemsSource="{Binding Modes}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Name}"
                                                                Command="{Binding $parent[ItemsControl].DataContext.SetModeCommand}"
                                                                CommandParameter="{Binding}" Margin="0,0,6,6"
                                                                Background="Transparent" Foreground="{DynamicResource FgDim}"
                                                                BorderBrush="{DynamicResource Line}" BorderThickness="1"
                                                                CornerRadius="7" Padding="10,4" FontSize="12"
                                                                AutomationProperties.Name="Switch mode" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding CurrentModeName, StringFormat='Current mode: {0}'}"
                                                       Foreground="{DynamicResource Accent}" FontSize="11" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <TextBlock IsVisible="{Binding !HasModes}"
                                                   Text="This agent doesn't expose live modes. Use Stop to halt the current turn, or Fork to start a fresh session that asks for approval."
                                                   Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- Sandbox: isolation status + lifecycle -->
                        <Button IsVisible="{Binding Session.HasSandbox}" Background="Transparent" Foreground="{DynamicResource FgDim}"
                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6" Padding="9,3" FontSize="11"
                                AutomationProperties.Name="Sandbox">
                            <TextBlock Text="{Binding Session.SandboxSummary}" />
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <StackPanel Width="280" Spacing="8">
                                        <TextBlock Text="{Binding Session.Sandbox.Id, StringFormat='Sandbox: {0}'}"
                                                   Foreground="{DynamicResource Fg}" FontWeight="SemiBold" FontSize="12"
                                                   FontFamily="{StaticResource MonoFont}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Session.Sandbox.Provider, StringFormat='Provider: {0}'}"
                                                   Foreground="{DynamicResource FgDim}" FontSize="11" />
                                        <TextBlock Text="{Binding Session.Sandbox.State, StringFormat='State: {0}'}"
                                                   Foreground="{DynamicResource FgDim}" FontSize="11" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="Pause" Command="{Binding Session.PauseSandboxCommand}"
                                                    Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                                    BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="10,5" FontSize="12" />
                                            <Button Content="Resume" Command="{Binding Session.ResumeSandboxCommand}"
                                                    Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                                    BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="10,5" FontSize="12" />
                                            <Button Content="Delete" Command="{Binding Session.DeleteSandboxCommand}"
                                                    Background="Transparent" Foreground="#E5484D"
                                                    BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="10,5" FontSize="12" />
                                        </StackPanel>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- session menu -->
                        <!-- Git: branch + commit -->
                        <Button IsVisible="{Binding Session.HasGit}" Background="Transparent" Foreground="{DynamicResource FgDim}"
                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6" Padding="9,3" FontSize="11"
                                AutomationProperties.Name="Git">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="⎇" FontSize="12" />
                                <TextBlock Text="{Binding Session.GitBranch}" />
                                <Border Width="6" Height="6" CornerRadius="3" Background="{DynamicResource Accent}"
                                        VerticalAlignment="Center" IsVisible="{Binding Session.GitDirty}" />
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <StackPanel Width="340" Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Session.GitBranch, StringFormat='Branch: {0}'}"
                                                       Foreground="{DynamicResource Fg}" FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Grid.Column="1" Text="{Binding Session.GitSummary}" Foreground="{DynamicResource FgDim}" FontSize="11" />
                                        </Grid>
                                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding Session.GitChanges}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                                        <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Accent}" FontSize="11"
                                                                   Width="26" FontFamily="{StaticResource MonoFont}" />
                                                        <TextBlock Text="{Binding Path}" Foreground="{DynamicResource Fg}" FontSize="12"
                                                                   FontFamily="{StaticResource MonoFont}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        </ScrollViewer>
                                        <TextBox Text="{Binding Session.CommitMessage, Mode=TwoWay}" Watermark="Commit message"
                                                 Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                                 BorderBrush="{DynamicResource Line}" CornerRadius="7" Padding="9,5" FontSize="12"
                                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="52"
                                                 AutomationProperties.Name="Commit message" />
                                        <Button Content="Commit all changes" Command="{Binding Session.CommitCommand}"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                Background="{DynamicResource Accent}" Foreground="#1A1200" CornerRadius="7" Padding="10,6" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <Button Content="⋯" Background="Transparent" Foreground="{DynamicResource FgDim}"
                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6" Padding="9,2" FontSize="12"
                                VerticalContentAlignment="Center" IsVisible="{Binding IsLive}" AutomationProperties.Name="Session menu">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="Rename / tag…" Command="{Binding BeginRenameCommand}" />
                                    <MenuItem Header="Pin tab" Command="{Binding TogglePinCommand}" />
                                    <MenuItem Header="Copy session link (hand off to another device)" Click="OnCopySessionLink" />
                                    <MenuItem Header="Schedule the composer prompt (every 5 min)" Command="{Binding Session.ScheduleCommand}" />
                                    <Separator />
                                    <MenuItem Header="Compact context" Command="{Binding Session.CompactCommand}"
                                              ToolTip.Tip="Ask the agent to summarise and free up its context window." />
                                    <MenuItem Header="Clear conversation" Command="{Binding Session.ClearContextCommand}"
                                              ToolTip.Tip="Ask the agent to start fresh (clears its context)." />
                                    <MenuItem Header="Restart agent" Command="{Binding Session.RestartAgentCommand}"
                                              ToolTip.Tip="Relaunch the agent process and resume the conversation — recovers a crashed or hung agent." />
                                    <Separator />
                                    <MenuItem Header="Open in new window" Command="{Binding MoveToWindowCommand}" />
                                    <Separator />
                                    <MenuItem Header="Duplicate (same session)" Command="{Binding DuplicateCommand}" />
                                    <MenuItem Header="Fork (copy working folder)…" Command="{Binding ForkCommand}" />
                                    <Separator />
                                    <MenuItem Header="Archive" Command="{Binding ArchiveCommand}" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- inline rename / tag editor -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0" IsVisible="{Binding IsRenaming}">
                    <TextBox Text="{Binding RenameText, Mode=TwoWay}" Width="240" Watermark="Tab name"
                             Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Line}" CornerRadius="7" Padding="9,4" FontSize="12"
                             AutomationProperties.Name="Rename tab">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding CommitRenameCommand}" />
                            <KeyBinding Gesture="Escape" Command="{Binding CancelRenameCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                    <Button Content="Save" Command="{Binding CommitRenameCommand}"
                            Background="{DynamicResource Accent}" Foreground="#1A1200" CornerRadius="7" Padding="12,4" FontSize="12" />
                    <TextBox Text="{Binding TagInput, Mode=TwoWay}" Width="160" Watermark="Add tag + Enter"
                             Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Line}" CornerRadius="7" Padding="9,4" FontSize="12"
                             AutomationProperties.Name="Add tag">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding AddTagCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                    <Button Content="Done" Command="{Binding CancelRenameCommand}"
                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="12,4" FontSize="12" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">

            <!-- Stage 1: pick a host -->
            <Border Padding="24" IsVisible="{Binding IsPickingHost}">
                <StackPanel MaxWidth="460" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <TextBlock Text="New session" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource Fg}" HorizontalAlignment="Center" />
                    <TextBlock Text="Choose a host" Foreground="{DynamicResource FgDim}" HorizontalAlignment="Center" />
                    <!-- While connecting, disable the picker and show progress so it doesn't look frozen (defect #8). -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center"
                                IsVisible="{Binding IsConnectingHost}">
                        <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                                     Foreground="{DynamicResource Accent}" Background="{DynamicResource PanelAlt}" />
                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource FgDim}" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                    <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  IsEnabled="{Binding !IsConnectingHost}">
                    <ItemsControl ItemsSource="{Binding Hosts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Button Command="{Binding Select}" HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left" CornerRadius="10"
                                            Padding="14,12" Background="{DynamicResource Panel}"
                                            BorderBrush="{DynamicResource Line}" BorderThickness="1">
                                        <StackPanel Margin="0,0,22,0">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Fg}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Url}" Foreground="{DynamicResource FgFaint}" FontSize="11" />
                                        </StackPanel>
                                    </Button>
                                    <!-- Remove a saved host (built-in hosts have no Forget command → hidden). Defect #7. -->
                                    <Button Command="{Binding Forget}" IsVisible="{Binding CanForget}" Content="✕"
                                            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                                            Background="Transparent" Foreground="{DynamicResource FgFaint}" BorderThickness="0"
                                            Padding="7,3" FontSize="12" Cursor="Hand"
                                            ToolTip.Tip="Remove this host" AutomationProperties.Name="Remove host" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>
                    <Button Command="{Binding ToggleAddHostCommand}" HorizontalAlignment="Left"
                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="10,6" FontSize="12"
                            Content="+ Add host" />
                    <StackPanel Spacing="6" IsVisible="{Binding ShowAddHost}">
                        <TextBox Text="{Binding NewHostName, Mode=TwoWay}" Watermark="Name (optional)"
                                 Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                 BorderBrush="{DynamicResource Line}" CornerRadius="8" Padding="10,8" />
                        <TextBox Text="{Binding NewHostUrl, Mode=TwoWay}" Watermark="https://host:5081"
                                 Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                 BorderBrush="{DynamicResource Line}" CornerRadius="8" Padding="10,8" />

                        <!-- GitHub SSO — shown when the host advertises it (GET /auth/methods). -->
                        <Button Content="Sign in with GitHub" Command="{Binding SignInWithGitHubCommand}"
                                IsVisible="{Binding HostSupportsGitHub}" IsEnabled="{Binding !IsGitHubAuthorizing}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="12,8" FontWeight="SemiBold" />
                        <Border IsVisible="{Binding IsGitHubAuthorizing}" Background="{DynamicResource PanelAlt}"
                                BorderBrush="{DynamicResource Accent}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Enter this code at github.com/login/device (opened in your browser):"
                                           Foreground="{DynamicResource FgDim}" FontSize="11" TextWrapping="Wrap" />
                                <SelectableTextBlock Text="{Binding GitHubUserCode}" Foreground="{DynamicResource Accent}"
                                                     FontFamily="{StaticResource MonoFont}" FontSize="20" FontWeight="Bold" />
                                <TextBlock Text="{Binding GitHubVerificationUri}" Foreground="{DynamicResource FgFaint}" FontSize="11" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressBar IsIndeterminate="True" Width="90" Height="4" VerticalAlignment="Center"
                                                 Foreground="{DynamicResource Accent}" Background="{DynamicResource Panel}" />
                                    <TextBlock Text="Waiting for you to authorize…" Foreground="{DynamicResource FgFaint}"
                                               FontSize="11" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- Keypair (SSH authorized_keys style) — shown when the host advertises it. -->
                        <Button Content="Sign in with a key" Command="{Binding SignInWithKeyCommand}"
                                IsVisible="{Binding HostSupportsKeypair}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="12,8" FontWeight="SemiBold" />
                        <Border IsVisible="{Binding ShowKeyInfo}" Background="{DynamicResource PanelAlt}"
                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="If the host rejects the key, add this line to its ~/.agnes/authorized_keys and retry:"
                                           Foreground="{DynamicResource FgDim}" FontSize="11" TextWrapping="Wrap" />
                                <SelectableTextBlock Text="{Binding PublicKeyLine}" Foreground="{DynamicResource Fg}"
                                                     FontFamily="{StaticResource MonoFont}" FontSize="10" TextWrapping="Wrap"
                                                     ctl:SelectionContextMenu.Enable="True" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="— or use a pairing code —" Foreground="{DynamicResource FgFaint}" FontSize="10"
                                   HorizontalAlignment="Center" IsVisible="{Binding HostSupportsGitHub}" />

                        <!-- Pairing code — shown unless the host disabled it. -->
                        <StackPanel Spacing="6" IsVisible="{Binding HostSupportsPairing}">
                            <TextBox Text="{Binding NewHostToken, Mode=TwoWay}" Watermark="Pairing code (from the host)"
                                     Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                     BorderBrush="{DynamicResource Line}" CornerRadius="8" Padding="10,8"
                                     ToolTip.Tip="Enter the pairing code the host prints at startup. A per-device token is issued and stored." />
                            <Button Content="Connect" Command="{Binding AddHostCommand}" HorizontalAlignment="Stretch"
                                    Background="{DynamicResource Accent}" Foreground="#1A1200" CornerRadius="8" Padding="12,8" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource FgFaint}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" />
                    <!-- First-run guidance -->
                    <TextBlock Text="First time? Start a host (docker compose up, or dotnet run in src/Agnes.Host), then Add host with the pairing code it prints. Or try the Simulated host above."
                               Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap"
                               TextAlignment="Center" MaxWidth="380" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <!-- Stage 2: configure the session (working dir · permissions · git push · agent) -->
            <Border Padding="24" IsVisible="{Binding IsPickingAgent}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="500" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                    <Button Command="{Binding BackCommand}" HorizontalAlignment="Left" Background="Transparent"
                            Foreground="{DynamicResource FgDim}" BorderThickness="0" Padding="0" FontSize="12" Content="‹ Hosts" />
                    <StackPanel Spacing="2">
                        <TextBlock Text="Configure session" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Fg}" HorizontalAlignment="Center" />
                        <TextBlock Text="Set the project and options, choose an agent, then start."
                                   Foreground="{DynamicResource FgDim}" FontSize="12" HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Working directory (the project the agent works on, on the host) -->
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Working directory (on the host)" Foreground="{DynamicResource FgDim}" FontSize="11" VerticalAlignment="Center" />
                            <ctl:InfoHint Description="The project folder the agent works in — a path on the host running the daemon. It becomes the agent's working directory; in a sandbox it's bind-mounted to /work, so the agent sees exactly these files and its edits/commits write back here. Its git remote also scopes what the agent may push."
                                          Security="Only this folder is exposed to a sandboxed agent — everything else on the host stays isolated. Because it's the real folder (not a copy), branch/checkout actions move your host checkout too; use the worktree option to insulate it." />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox Grid.Column="0" Text="{Binding WorkingDirectory, Mode=TwoWay}" Watermark="/path/to/your/project"
                                     Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                     BorderBrush="{DynamicResource Line}" CornerRadius="8" Padding="10,8" FontSize="12"
                                     FontFamily="{StaticResource MonoFont}" />
                            <Button Grid.Column="1" Content="Browse…" Click="OnBrowseWorkingDirectory"
                                    Background="Transparent" Foreground="{DynamicResource FgDim}"
                                    BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="10,8" FontSize="12"
                                    ToolTip.Tip="Pick a folder on this machine (for a local host)" />
                        </Grid>
                    </StackPanel>

                    <!-- Sandbox: isolate the agent in a per-session VM. Defaults on when the host supports it. -->
                    <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="10" Padding="14,10">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="📦" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Foreground="{DynamicResource Fg}" FontSize="13" FontWeight="SemiBold" Text="Sandbox" />
                                    <ctl:InfoHint Description="Run the agent inside an isolated per-session VM, with only the chosen project directory mounted. On by default when the host supports it."
                                                  Security="A sandbox contains what the agent can reach — it can't touch the rest of your machine, even in Autonomous mode. Strongly recommended." />
                                </StackPanel>
                                <TextBlock Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap"
                                           IsVisible="{Binding SandboxAvailable}"
                                           Text="Isolate the agent in a per-session VM — only the project directory is mounted." />
                                <TextBlock Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap"
                                           IsVisible="{Binding !SandboxAvailable}"
                                           Text="Not available on this host — start it with a sandbox provider (Agnes:Sandbox:Provider=incus) to isolate sessions." />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                        IsEnabled="{Binding SandboxAvailable}">
                                <Button Content="On" Command="{Binding SetSandboxModeCommand}" CommandParameter="On"
                                        Classes.on="{Binding SandboxOn}" Classes="seg" />
                                <Button Content="Off" Command="{Binding SetSandboxModeCommand}" CommandParameter="Off"
                                        Classes.on="{Binding SandboxOff}" Classes="seg" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Permissions: fixed label/description on the left; the segmented control on the right is the state -->
                    <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="10" Padding="14,10">
                        <Grid ColumnDefinitions="Auto,*,Auto" >
                            <TextBlock Grid.Column="0" Text="🛡" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Foreground="{DynamicResource Fg}" FontSize="13" FontWeight="SemiBold" Text="Permissions" />
                                    <ctl:InfoHint Description="Whether the agent asks before each tool call. Ask: you approve every file edit, command, and other tool use as it happens. Autonomous: the agent runs tools without asking."
                                                  Security="Autonomous mode lets the agent edit files and run commands with no approval. Use it only for work you trust, and prefer a sandbox so it can't touch anything outside the mounted project." />
                                </StackPanel>
                                <TextBlock Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap"
                                           Text="Whether the agent asks you before running each tool." />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Button Content="Ask" Command="{Binding SetPermissionModeCommand}" CommandParameter="Ask"
                                        Classes.on="{Binding PermAsk}" Classes="seg" />
                                <Button Content="Autonomous" Command="{Binding SetPermissionModeCommand}" CommandParameter="Autonomous"
                                        Classes.on="{Binding PermAutonomous}" Classes="seg" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Git push for a sandboxed session: fixed label/description; the Off/Ask/Trust segment is the state -->
                    <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="10" Padding="14,10">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="⑂" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Foreground="{DynamicResource Fg}" FontSize="13" FontWeight="SemiBold" Text="GitHub access" />
                                    <ctl:InfoHint Description="Whether a sandboxed agent may use your linked GitHub account to clone, fetch and push. Off: no credentials. Ask: allowed, but you approve each repository once (the first time the agent touches it). Trust: allowed for every repo without asking. The credential is a scoped, short-lived, per-repo token minted on the host."
                                                  Security="The token never enters the sandbox and is scoped to the specific repo requested, so access to one repo can't reach your others. Cloning/pushing only works for repos your linked account can access." />
                                </StackPanel>
                                <TextBlock Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap"
                                           Text="Let the agent clone/push private repos — approved once per repository." />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Button Content="Off" Command="{Binding SetGitCredentialModeCommand}" CommandParameter="Off"
                                        Classes.on="{Binding GitCredOff}" Classes="seg" />
                                <Button Content="Ask" Command="{Binding SetGitCredentialModeCommand}" CommandParameter="Ask"
                                        Classes.on="{Binding GitCredAsk}" Classes="seg" />
                                <Button Content="Trust" Command="{Binding SetGitCredentialModeCommand}" CommandParameter="Trust"
                                        Classes.on="{Binding GitCredTrust}" Classes="seg" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Agent: label + search (scales past a handful) + selectable list; opens only on Start -->
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0" Text="AGENT" Foreground="{DynamicResource FgDim}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding AgentFilter, Mode=TwoWay}" Watermark="Search agents…"
                                     Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                     BorderBrush="{DynamicResource Line}" CornerRadius="8" Padding="9,5" FontSize="12" MaxWidth="220"
                                     HorizontalAlignment="Right" AutomationProperties.Name="Search agents" />
                        </Grid>
                        <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Agents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="agent" Classes.sel="{Binding IsSelected}"
                                            Command="{Binding $parent[ItemsControl].DataContext.SelectAgentChoiceCommand}"
                                            CommandParameter="{Binding}" IsEnabled="{Binding Available}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,2" CornerRadius="8"
                                            Padding="12,8" Background="{DynamicResource Panel}"
                                            BorderBrush="{DynamicResource Line}" BorderThickness="1"
                                            ToolTip.Tip="{Binding StatusText}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource Fg}" FontWeight="SemiBold" FontSize="13" />
                                                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource FgFaint}" FontSize="10"
                                                           FontFamily="{StaticResource MonoFont}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="✓" Foreground="{DynamicResource Accent}" FontWeight="Bold"
                                                       FontSize="14" VerticalAlignment="Center" IsVisible="{Binding IsSelected}" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Explicit start: no surprise auto-progress when an agent is clicked -->
                    <Button Content="Start session" Command="{Binding StartSessionCommand}" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" Background="{DynamicResource Accent}" Foreground="#1A1200"
                            CornerRadius="8" Padding="12,9" FontWeight="SemiBold" FontSize="13"
                            AutomationProperties.Name="Start session" />
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource FgFaint}" HorizontalAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Stage 2b: starting — opening the session (the host may be baking the sandbox image) -->
            <Border Padding="24" IsVisible="{Binding IsStarting}">
                <StackPanel MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <TextBlock Text="Starting session" FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource Fg}" HorizontalAlignment="Center" />
                    <ProgressBar IsIndeterminate="True" Height="6" MinWidth="300"
                                 Foreground="{DynamicResource Accent}" Background="{DynamicResource PanelAlt}" />
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource FgDim}" FontSize="12"
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                               AutomationProperties.LiveSetting="Polite" />
                    <TextBlock Text="The host may be building the sandbox image — installing tools and the agent CLIs into a fresh VM. This can take a few minutes the first time; it's cached afterwards."
                               Foreground="{DynamicResource FgFaint}" FontSize="11" HorizontalAlignment="Center"
                               TextAlignment="Center" TextWrapping="Wrap" MaxWidth="360" />
                    <!-- Never trap the user on an opaque wait: Cancel drops back to the agent picker (defect #8/#10). -->
                    <Button Content="Cancel" Command="{Binding CancelStartCommand}" HorizontalAlignment="Center"
                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="16,5" FontSize="12"
                            AutomationProperties.Name="Cancel starting the session" />
                </StackPanel>
            </Border>

            <!-- Stage 3: live conversation — resizable multi-column workspace -->
            <Grid IsVisible="{Binding IsLive}" RowDefinitions="Auto,*">

                <!-- Clear connection / session state banner -->
                <Border Grid.Row="0" DataContext="{Binding Session}" IsVisible="{Binding ShowBanner}"
                        Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource Accent}"
                        BorderThickness="0,0,0,1" Padding="16,8">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                                Background="{DynamicResource Accent}" Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1" Text="{Binding BannerText}" Foreground="{DynamicResource Fg}"
                                   VerticalAlignment="Center" FontSize="12" TextWrapping="Wrap"
                                   AutomationProperties.LiveSetting="Assertive" />
                        <Button Grid.Column="2" Content="Retry" Command="{Binding RetryCommand}" IsVisible="{Binding CanRetry}"
                                Background="{DynamicResource Accent}" Foreground="#1A1200" CornerRadius="7" Padding="12,4"
                                FontSize="12" Margin="8,0,0,0" ToolTip.Tip="Retry the connection or resend the interrupted turn" />
                        <Button Grid.Column="3" Content="Dismiss" Command="{Binding DismissBannerCommand}"
                                Background="Transparent" Foreground="{DynamicResource FgDim}"
                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="12,4"
                                FontSize="12" Margin="8,0,0,0" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1" x:Name="Workspace" DataContext="{Binding Session}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0" MinWidth="0" MaxWidth="560" />
                        <ColumnDefinition Width="0" />
                        <ColumnDefinition Width="*" MinWidth="300" />
                        <ColumnDefinition Width="0" />
                        <ColumnDefinition Width="0" MinWidth="0" MaxWidth="760" />
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: plan, files modified, tools run -->
                    <Border Grid.Column="0" IsVisible="{Binding ShowLeftPanel}"
                            Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0">
                        <ScrollViewer Padding="14,16" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="18">
                                <!-- Session name: the agent's auto-generated title when it has one, else the folder -->
                                <StackPanel Spacing="2">
                                    <TextBlock Text="SESSION" Foreground="{DynamicResource FgDim}" FontSize="11" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding DisplayTitle}" Foreground="{DynamicResource Fg}" FontSize="14"
                                               FontWeight="SemiBold" TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Agent / subagent tree -->
                                <StackPanel Spacing="6" IsVisible="{Binding HasSubagents}">
                                    <TextBlock Text="AGENTS" Foreground="{DynamicResource FgDim}" FontSize="11" FontWeight="SemiBold" />
                                    <TreeView ItemsSource="{Binding AgentTree}" Background="Transparent" BorderThickness="0">
                                        <TreeView.ItemTemplate>
                                            <TreeDataTemplate DataType="vm:AgentNode" ItemsSource="{Binding Children}">
                                                <Button Command="{Binding SelectCommand}" HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                        Padding="2,3" Cursor="Hand" Classes.sel="{Binding IsSelected}">
                                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                                        <TextBlock Text="◆" FontSize="9" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource Good}" IsVisible="{Binding IsMain}" />
                                                        <TextBlock Text="•" FontSize="12" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource FgFaint}" IsVisible="{Binding !IsMain}" />
                                                        <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Button>
                                            </TreeDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>
                                </StackPanel>

                                <StackPanel Spacing="6" IsVisible="{Binding Plan, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
                                    <TextBlock Text="PLAN" Foreground="{DynamicResource FgDim}" FontSize="11" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding Plan.Entries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3">
                                                    <TextBlock Text="{Binding Status}" Foreground="{DynamicResource FgFaint}" FontSize="10" Width="70" />
                                                    <TextBlock Text="{Binding Content}" Foreground="{DynamicResource Fg}" FontSize="12" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Spacing="4" IsVisible="{Binding HasFiles}">
                                    <Button Command="{Binding ToggleFilesCommand}" Background="Transparent" BorderThickness="0"
                                            Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="▾" FontSize="9" Foreground="{DynamicResource FgFaint}" VerticalAlignment="Center"
                                                       IsVisible="{Binding FilesExpanded}" />
                                            <TextBlock Text="▸" FontSize="9" Foreground="{DynamicResource FgFaint}" VerticalAlignment="Center"
                                                       IsVisible="{Binding !FilesExpanded}" />
                                            <TextBlock Text="FILES MODIFIED" Foreground="{DynamicResource FgDim}" FontSize="11" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>
                                    <ItemsControl ItemsSource="{Binding ModifiedFiles}" IsVisible="{Binding FilesExpanded}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding $parent[ItemsControl].DataContext.ShowFilePreviewCommand}"
                                                        CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                        Padding="6,5" CornerRadius="6" Cursor="Hand" ToolTip.Tip="Open the diff">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Fg}" FontSize="12"
                                                                   FontFamily="{StaticResource MonoFont}" />
                                                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource FgFaint}" FontSize="10" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Spacing="4" IsVisible="{Binding HasTools}">
                                    <Button Command="{Binding ToggleToolsListCommand}" Background="Transparent" BorderThickness="0"
                                            Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="▾" FontSize="9" Foreground="{DynamicResource FgFaint}" VerticalAlignment="Center"
                                                       IsVisible="{Binding ToolsListExpanded}" />
                                            <TextBlock Text="▸" FontSize="9" Foreground="{DynamicResource FgFaint}" VerticalAlignment="Center"
                                                       IsVisible="{Binding !ToolsListExpanded}" />
                                            <TextBlock Text="TOOLS RUN" Foreground="{DynamicResource FgDim}" FontSize="11" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>
                                    <StackPanel Spacing="4" IsVisible="{Binding ToolsListExpanded}">
                                        <ItemsControl ItemsSource="{Binding VisibleToolActivity}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding $parent[ItemsControl].DataContext.ShowFilePreviewCommand}"
                                                            CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                            Padding="6,5" CornerRadius="6" Cursor="Hand">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding Kind}" Foreground="{DynamicResource Good}" FontSize="10"
                                                                       FontFamily="{StaticResource MonoFont}" Width="52" />
                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Fg}" FontSize="12"
                                                                       FontFamily="{StaticResource MonoFont}" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- Only the most recent 50 render until asked for the rest. -->
                                        <Button Content="{Binding MoreToolsLabel}" Command="{Binding ShowAllToolsCommand}"
                                                IsVisible="{Binding HasMoreTools}" HorizontalAlignment="Left" Cursor="Hand"
                                                Background="Transparent" Foreground="{DynamicResource Accent}" BorderThickness="0"
                                                Padding="6,3" FontSize="11" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Audit trail: capabilities granted / denied -->
                                <StackPanel Spacing="4" IsVisible="{Binding HasApprovals}">
                                    <TextBlock Text="APPROVALS" Foreground="{DynamicResource FgDim}" FontSize="11" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding Approvals}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3">
                                                    <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                                                            Background="{DynamicResource Good}" IsVisible="{Binding Allowed}" />
                                                    <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                                                            Background="{DynamicResource Accent}" IsVisible="{Binding !Allowed}" />
                                                    <TextBlock Text="{Binding TimeText}" Foreground="{DynamicResource FgFaint}" FontSize="10"
                                                               FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Fg}" FontSize="12"
                                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- MCP CALLS: forwarded host MCP tools a sandboxed agent invoked -->
                                <StackPanel Spacing="4" IsVisible="{Binding HasMcpCalls}">
                                    <TextBlock Text="MCP CALLS" Foreground="{DynamicResource FgDim}" FontSize="11" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding McpCalls}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3">
                                                    <TextBlock Text="{Binding TimeText}" Foreground="{DynamicResource FgFaint}" FontSize="10"
                                                               FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Fg}" FontSize="12"
                                                               FontFamily="{StaticResource MonoFont}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- CREDENTIALS: brokered git-credential grants for a sandboxed session -->
                                <StackPanel Spacing="4" IsVisible="{Binding HasCredentialUses}">
                                    <TextBlock Text="CREDENTIALS" Foreground="{DynamicResource FgDim}" FontSize="11" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding CredentialUses}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3">
                                                    <TextBlock Text="{Binding TimeText}" Foreground="{DynamicResource FgFaint}" FontSize="10"
                                                               FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Fg}" FontSize="12"
                                                               FontFamily="{StaticResource MonoFont}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource FgFaint}" FontSize="10" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns"
                                  Background="{DynamicResource Line}" IsVisible="{Binding ShowLeftPanel}" />

                    <!-- MIDDLE: chat -->
                    <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto,Auto" IsVisible="{Binding ShowChat}">

                        <!-- within-session search (Ctrl+F) -->
                        <Border Grid.Row="0" IsVisible="{Binding IsSearchOpen}" Background="{DynamicResource Panel}"
                                BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="24,8">
                            <StackPanel MaxWidth="768" HorizontalAlignment="Center" Spacing="6">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                                    <TextBox Grid.Column="0" Text="{Binding SearchQuery, Mode=TwoWay}" Watermark="Search this session…"
                                             Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                             BorderBrush="{DynamicResource Line}" CornerRadius="7" Padding="9,4" FontSize="12"
                                             AutomationProperties.Name="Search this session">
                                        <TextBox.KeyBindings>
                                            <KeyBinding Gesture="Enter" Command="{Binding NextMatchCommand}" />
                                            <KeyBinding Gesture="Shift+Enter" Command="{Binding PrevMatchCommand}" />
                                            <KeyBinding Gesture="Escape" Command="{Binding CloseSearchCommand}" />
                                        </TextBox.KeyBindings>
                                    </TextBox>
                                    <TextBlock Grid.Column="1" Text="{Binding MatchSummary}" Foreground="{DynamicResource FgFaint}"
                                               FontSize="11" VerticalAlignment="Center" MinWidth="52" />
                                    <Button Grid.Column="2" Content="‹" Command="{Binding PrevMatchCommand}"
                                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6" Padding="9,2"
                                            AutomationProperties.Name="Previous match" />
                                    <Button Grid.Column="3" Content="›" Command="{Binding NextMatchCommand}"
                                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6" Padding="9,2"
                                            AutomationProperties.Name="Next match" />
                                    <Button Grid.Column="4" Content="✕" Command="{Binding CloseSearchCommand}"
                                            Background="Transparent" Foreground="{DynamicResource FgDim}" BorderThickness="0"
                                            Padding="8,2" AutomationProperties.Name="Close search" />
                                </Grid>
                                <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Matches}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding $parent[ItemsControl].DataContext.SelectHitCommand}"
                                                    CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                    Padding="6,3" CornerRadius="5" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Kind}" Foreground="{DynamicResource Good}" FontSize="10"
                                                               Width="56" FontFamily="{StaticResource MonoFont}" />
                                                    <TextBlock Text="{Binding Snippet}" Foreground="{DynamicResource FgDim}" FontSize="11"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <!-- Transcript: a virtualizing ListBox so a long conversation only realizes the
                             rows on screen. Full-width (scrollbar at the window edge) with each row
                             centred at the 768px reading width. Selection is disabled — the rows carry
                             their own buttons. -->
                        <!-- Empty state: a fresh session shows a cue instead of a blank column (defect #10). -->
                        <StackPanel Grid.Row="1" IsHitTestVisible="False" IsVisible="{Binding IsTranscriptEmpty}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6" MaxWidth="420">
                            <TextBlock Text="No messages yet" Foreground="{DynamicResource FgDim}" FontSize="14"
                                       FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="Send a message below to start the conversation."
                                       Foreground="{DynamicResource FgFaint}" FontSize="12"
                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                        </StackPanel>

                        <ListBox Grid.Row="1" x:Name="Transcript" ItemsSource="{Binding DisplayItems}"
                                 IsVisible="{Binding !IsInspectorOpen}"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="24,16" HorizontalAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.Styles>
                                <!-- The transcript is read-only: rows don't select or take focus, so it
                                     behaves like a plain list while still virtualizing. -->
                                <Style Selector="ListBoxItem">
                                    <Setter Property="MaxWidth" Value="768" />
                                    <!-- Stretch (not Center): a stretch item clamped by MaxWidth fills the
                                         768px column and is centred, rather than shrinking to its content. -->
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                            </ListBox.Styles>
                            <ListBox.DataTemplates>

                                    <DataTemplate DataType="tr:MessageBubbleItem">
                                        <Border Classes="msg" Classes.user="{Binding IsUser}" CornerRadius="12" Padding="14,10" Margin="0,6">
                                            <!-- Right-click / long-press anywhere on the bubble → the same per-message
                                                 actions, so touch and mouse reach them without the hover-only ⋯. -->
                                            <Border.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuItem Header="Copy message" Click="OnCopyMessage" />
                                                    <MenuItem Header="View from here"
                                                              Command="{Binding $parent[ItemsControl].DataContext.RewindToCommand}"
                                                              CommandParameter="{Binding}" />
                                                </MenuFlyout>
                                            </Border.ContextFlyout>
                                            <StackPanel>
                                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,3">
                                                    <TextBlock Grid.Column="0" Text="{Binding Speaker}" FontSize="11"
                                                               Foreground="{DynamicResource FgFaint}" VerticalAlignment="Center" />
                                                    <!-- Per-message actions; only visible on hover (see Border.msg styles). -->
                                                    <Button Grid.Column="1" Classes="rowmenu" Content="⋯" Background="Transparent"
                                                            Foreground="{DynamicResource FgDim}" BorderThickness="0" Padding="6,0" FontSize="15"
                                                            Cursor="Hand" VerticalAlignment="Center" AutomationProperties.Name="Message actions">
                                                        <Button.Flyout>
                                                            <MenuFlyout>
                                                                <MenuItem Header="Copy message" Click="OnCopyMessage" />
                                                                <MenuItem Header="View from here"
                                                                          Command="{Binding $parent[ItemsControl].DataContext.RewindToCommand}"
                                                                          CommandParameter="{Binding}" />
                                                            </MenuFlyout>
                                                        </Button.Flyout>
                                                    </Button>
                                                </Grid>
                                                <!-- Full message rendered as selectable Markdown; thoughts stay plain italic. -->
                                                <mdxaml:MarkdownScrollViewer Markdown="{Binding Text}" IsVisible="{Binding !IsThought}"
                                                                             SelectionEnabled="True" ctl:SelectionContextMenu.Enable="True" />
                                                <SelectableTextBlock Text="{Binding Text}" Classes="thought" IsVisible="{Binding IsThought}"
                                                                     TextWrapping="Wrap" ctl:SelectionContextMenu.Enable="True" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>

                                    <!-- Compact, dense single-line tool call (this is a developer tool): no
                                         card chrome, tight margins. Full output opens in the preview pane on
                                         click; the "Tool output" toggle reveals a one-line summary under each. -->
                                    <DataTemplate DataType="tr:ToolCallItem">
                                        <Button Classes="tool" Command="{Binding $parent[ItemsControl].DataContext.ShowToolPreviewCommand}"
                                                CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch" Margin="0,1" Padding="4,2" CornerRadius="4"
                                                Cursor="Hand" Background="Transparent" BorderThickness="0"
                                                ToolTip.Tip="Open the full tool output">
                                            <StackPanel Spacing="1">
                                                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Text="▸" Foreground="{DynamicResource Good}"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="12" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding KindLabel}" Foreground="{DynamicResource FgDim}"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="12" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Title}" Foreground="{DynamicResource Fg}"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="12" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="3" Text="{Binding StatusText}" Foreground="{DynamicResource FgFaint}"
                                                               FontSize="11" VerticalAlignment="Center" IsVisible="{Binding ShowStatus}" />
                                                    <TextBlock Grid.Column="4" Text="{Binding DurationText}" Foreground="{DynamicResource FgFaint}"
                                                               FontSize="11" FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center"
                                                               IsVisible="{Binding HasDuration}" />
                                                </Grid>
                                                <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource FgFaint}"
                                                           FontFamily="{StaticResource MonoFont}" FontSize="11" Margin="20,0,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           IsVisible="{Binding $parent[ItemsControl].DataContext.ToolsExpanded}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>

                                    <DataTemplate DataType="tr:PlanItemView">
                                        <Border Margin="0,6" Padding="12,9" CornerRadius="8"
                                                Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="Plan" Foreground="{DynamicResource Fg}" FontWeight="SemiBold" Margin="0,0,0,4" />
                                                <ItemsControl ItemsSource="{Binding Entries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                                                <TextBlock Text="{Binding Status}" Foreground="{DynamicResource FgFaint}"
                                                                           FontSize="11" Width="90" />
                                                                <TextBlock Text="{Binding Content}" Foreground="{DynamicResource Fg}" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>

                                    <!-- Structured "ask the user" card (AskUserQuestion / requestUserInput). -->
                                    <DataTemplate DataType="tr:QuestionItem">
                                        <Border Margin="0,6" Padding="14,12" CornerRadius="10"
                                                Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Accent}" BorderThickness="1">
                                            <StackPanel Spacing="12">
                                                <TextBlock Text="The agent needs your input" Foreground="{DynamicResource Accent}"
                                                           FontWeight="SemiBold" FontSize="12" />
                                                <ItemsControl ItemsSource="{Binding Questions}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Spacing="6" Margin="0,0,0,6">
                                                                <Border Background="{DynamicResource AccentSoft}" CornerRadius="6" Padding="7,2"
                                                                        HorizontalAlignment="Left" IsVisible="{Binding Header, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
                                                                    <TextBlock Text="{Binding Header}" Foreground="{DynamicResource Accent}" FontSize="10" FontWeight="SemiBold" />
                                                                </Border>
                                                                <TextBlock Text="{Binding Prompt}" Foreground="{DynamicResource Fg}" FontSize="13" TextWrapping="Wrap" />
                                                                <ItemsControl ItemsSource="{Binding Options}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Panel Margin="0,2">
                                                                                <RadioButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                                             GroupName="{Binding $parent[ItemsControl].DataContext.GroupName}"
                                                                                             IsVisible="{Binding $parent[ItemsControl].DataContext.SingleSelect}">
                                                                                    <StackPanel Spacing="1">
                                                                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Fg}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                                                        <TextBlock Text="{Binding Description}" Foreground="{DynamicResource FgDim}" FontSize="11" TextWrapping="Wrap" />
                                                                                    </StackPanel>
                                                                                </RadioButton>
                                                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                                          IsVisible="{Binding $parent[ItemsControl].DataContext.MultiSelect}">
                                                                                    <StackPanel Spacing="1">
                                                                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Fg}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                                                        <TextBlock Text="{Binding Description}" Foreground="{DynamicResource FgDim}" FontSize="11" TextWrapping="Wrap" />
                                                                                    </StackPanel>
                                                                                </CheckBox>
                                                                            </Panel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBox Text="{Binding Notes, Mode=TwoWay}" Watermark="Notes (optional)"
                                                                         IsVisible="{Binding AllowFreeText}" AcceptsReturn="True" TextWrapping="Wrap"
                                                                         Background="{DynamicResource Panel}" Foreground="{DynamicResource Fg}"
                                                                         BorderBrush="{DynamicResource Line}" CornerRadius="7" Padding="9,5" FontSize="12" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding !Resolved}">
                                                    <Button Content="Submit" Command="{Binding $parent[ItemsControl].DataContext.AnswerQuestionCommand}"
                                                            CommandParameter="{Binding}" Background="{DynamicResource Accent}" Foreground="#1A1200"
                                                            CornerRadius="7" Padding="16,6" FontWeight="SemiBold" />
                                                    <Button Content="Dismiss" Command="{Binding $parent[ItemsControl].DataContext.DismissQuestionCommand}"
                                                            CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource FgDim}"
                                                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="16,6" />
                                                </StackPanel>
                                                <TextBlock Text="✓ Answered" Foreground="{DynamicResource Good}" FontSize="11"
                                                           IsVisible="{Binding Resolved}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>

                                    <DataTemplate DataType="tr:PermissionItem">
                                        <Border Margin="0,6" Padding="12,9" CornerRadius="8"
                                                Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Accent}" BorderThickness="1">
                                            <StackPanel Spacing="5">
                                                <TextBlock Text="Permission requested" Foreground="{DynamicResource Accent}"
                                                           FontWeight="SemiBold" FontSize="12" />
                                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Fg}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                                <!-- the five facts -->
                                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="2">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Touches" Foreground="{DynamicResource FgFaint}" FontSize="11" />
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ResourceText}" Foreground="{DynamicResource FgDim}"
                                                               FontSize="11" FontFamily="{StaticResource MonoFont}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Reversible" Foreground="{DynamicResource FgFaint}" FontSize="11" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ReversibleText}" Foreground="{DynamicResource FgDim}"
                                                               FontSize="11" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Why" Foreground="{DynamicResource FgFaint}" FontSize="11" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Rationale}" Foreground="{DynamicResource FgDim}"
                                                               FontSize="11" TextWrapping="Wrap" />
                                                </Grid>
                                                <TextBlock Text="{Binding NarrowestOptionHint}" Foreground="{DynamicResource Accent}" FontSize="11"
                                                           IsVisible="{Binding HasNarrowestHint}" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding ResolutionText}" Foreground="{DynamicResource FgDim}" FontSize="11"
                                                           IsVisible="{Binding ResolutionText, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>

                                    <DataTemplate DataType="tr:NoticeItem">
                                        <TextBlock Text="{Binding Text}" Foreground="{DynamicResource FgDim}"
                                                   FontStyle="Italic" Margin="0,6" TextWrapping="Wrap" />
                                    </DataTemplate>

                            </ListBox.DataTemplates>
                        </ListBox>

                        <!-- Sticky context: pin the last human/agent message above a run of tool calls when
                             no message is on screen, so you keep the thread while scrolling (defect #6).
                             Shown/populated from code-behind as the transcript scrolls. -->
                        <Border Grid.Row="1" x:Name="StickyHeader" IsVisible="False" VerticalAlignment="Top" ZIndex="4"
                                Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1"
                                Padding="24,6" IsHitTestVisible="False">
                            <StackPanel MaxWidth="768" HorizontalAlignment="Center" Spacing="1">
                                <TextBlock x:Name="StickySpeaker" Foreground="{DynamicResource FgFaint}" FontSize="10" />
                                <TextBlock x:Name="StickyText" Foreground="{DynamicResource FgDim}" FontSize="12"
                                           TextTrimming="CharacterEllipsis" MaxLines="1" />
                            </StackPanel>
                        </Border>

                        <!-- Thinking indicator: the agent is working even when it hasn't emitted output yet,
                             so there's always a sign it's still going (vs. stopped) — defect #4. -->
                        <Border Grid.Row="1" IsVisible="{Binding IsTurnActive}" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                Margin="0,0,0,10" ZIndex="4" IsHitTestVisible="False"
                                Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                                CornerRadius="12" Padding="12,5" BoxShadow="0 4 12 -4 #40000000">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Border Classes="pulse" Width="7" Height="7" CornerRadius="4"
                                        Background="{DynamicResource Accent}" VerticalAlignment="Center" />
                                <TextBlock Text="Thinking…" Foreground="{DynamicResource FgDim}" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Rewind (viewing history) banner -->
                        <Border Grid.Row="1" VerticalAlignment="Top" IsVisible="{Binding IsRewound}"
                                Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource Accent}"
                                BorderThickness="0,0,0,1" Padding="24,7" ZIndex="5">
                            <Grid ColumnDefinitions="*,Auto" MaxWidth="768" HorizontalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="Viewing earlier history (read-only)" Foreground="{DynamicResource Fg}"
                                           FontSize="12" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Resume" Command="{Binding ResumeCommand}"
                                        Background="{DynamicResource Accent}" Foreground="#1A1200" CornerRadius="7" Padding="12,4" FontSize="12" />
                            </Grid>
                        </Border>

                        <!-- Raw event / debug inspector (over the transcript) -->
                        <Border Grid.Row="1" IsVisible="{Binding IsInspectorOpen}" Background="{DynamicResource Bg}">
                            <Grid RowDefinitions="Auto,*">
                                <Border Grid.Row="0" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}"
                                        BorderThickness="0,0,0,1" Padding="24,8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="Event log" Foreground="{DynamicResource Fg}"
                                                   FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="✕" Command="{Binding ToggleInspectorCommand}"
                                                Background="Transparent" Foreground="{DynamicResource FgDim}" BorderThickness="0"
                                                Padding="8,2" AutomationProperties.Name="Close event log" />
                                    </Grid>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,8">
                                    <ItemsControl ItemsSource="{Binding RawEvents}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="44,86,120,*" Margin="0,1">
                                                    <TextBlock Grid.Column="0" Text="{Binding Sequence}" Foreground="{DynamicResource Gutter}"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="11" TextAlignment="Right" Padding="0,0,8,0" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Time}" Foreground="{DynamicResource FgFaint}"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="11" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Kind}" Foreground="{DynamicResource Good}"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Summary}" Foreground="{DynamicResource FgDim}"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Margin="24,4" Padding="14,10" CornerRadius="10"
                                Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource Accent}" BorderThickness="1"
                                IsVisible="{Binding PendingPermission, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
                            <Grid ColumnDefinitions="*,Auto,Auto" MaxWidth="768" HorizontalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding PendingPermission.Title}" Foreground="{DynamicResource Fg}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding PendingPermission.ResourceText}" Foreground="{DynamicResource FgDim}" FontSize="11"
                                                   FontFamily="{StaticResource MonoFont}" />
                                        <TextBlock Text="·" Foreground="{DynamicResource FgFaint}" FontSize="11" />
                                        <TextBlock Text="{Binding PendingPermission.ReversibleText}" Foreground="{DynamicResource FgDim}" FontSize="11" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding PendingPermission.NarrowestOptionHint}" Foreground="{DynamicResource Accent}" FontSize="11"
                                               IsVisible="{Binding PendingPermission.HasNarrowestHint}" />
                                </StackPanel>
                                <ItemsControl Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding PendingPermission.Options}"
                                              VerticalAlignment="Center" Margin="8,0,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="8" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}"
                                                    Command="{Binding $parent[ItemsControl].DataContext.RespondWithCommand}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" Foreground="{DynamicResource Fg}"
                                                    BorderBrush="{DynamicResource Accent}" BorderThickness="1" CornerRadius="7" Padding="12,6" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}"
                                BorderThickness="0,1,0,0" Padding="24,12">
                            <!-- Stretch (not Center) + MaxWidth: a fixed 768px block, centred — otherwise the
                                 panel sizes to content and the composer visibly resizes as you type. -->
                            <StackPanel Spacing="8" MaxWidth="768" HorizontalAlignment="Stretch">

                                <!-- Queued prompts (added while a turn runs; sent in order as turns end) -->
                                <StackPanel Spacing="4" IsVisible="{Binding HasQueue}">
                                    <TextBlock Text="QUEUED" Foreground="{DynamicResource FgDim}" FontSize="10" FontWeight="SemiBold" />
                                    <ScrollViewer MaxHeight="168" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding PendingPrompts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Line}"
                                                        BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,2">
                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                                        <TextBlock Grid.Column="0" Text="⋮" Foreground="{DynamicResource FgFaint}"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Text}" Foreground="{DynamicResource Fg}"
                                                                   FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                        <Button Grid.Column="2" Content="↑" Padding="6,1" FontSize="11" Background="Transparent"
                                                                Foreground="{DynamicResource FgDim}" BorderThickness="0" Cursor="Hand"
                                                                Command="{Binding $parent[ItemsControl].DataContext.MoveQueuedUpCommand}"
                                                                CommandParameter="{Binding}" AutomationProperties.Name="Move up" />
                                                        <Button Grid.Column="3" Content="↓" Padding="6,1" FontSize="11" Background="Transparent"
                                                                Foreground="{DynamicResource FgDim}" BorderThickness="0" Cursor="Hand"
                                                                Command="{Binding $parent[ItemsControl].DataContext.MoveQueuedDownCommand}"
                                                                CommandParameter="{Binding}" AutomationProperties.Name="Move down" />
                                                        <Button Grid.Column="4" Content="✕" Padding="6,1" FontSize="11" Background="Transparent"
                                                                Foreground="{DynamicResource FgFaint}" BorderThickness="0" Cursor="Hand"
                                                                Command="{Binding $parent[ItemsControl].DataContext.RemoveQueuedCommand}"
                                                                CommandParameter="{Binding}" AutomationProperties.Name="Remove from queue" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>

                                <!-- Slash-command suggestions -->
                                <Border IsVisible="{Binding ShowSlash}" Background="{DynamicResource PanelAlt}"
                                        BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="4">
                                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SlashSuggestions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding $parent[ItemsControl].DataContext.ApplySlashCommand}"
                                                        CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"
                                                        Padding="8,5" CornerRadius="6" Cursor="Hand">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Text="{Binding Name, StringFormat='/{0}'}" Foreground="{DynamicResource Accent}"
                                                                   FontFamily="{StaticResource MonoFont}" FontSize="12" Width="90" />
                                                        <TextBlock Text="{Binding Description}" Foreground="{DynamicResource FgDim}" FontSize="12" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    </ScrollViewer>
                                </Border>

                                <!-- Attached context chips -->
                                <ItemsControl ItemsSource="{Binding Attachments}" IsVisible="{Binding HasAttachments}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Line}"
                                                    BorderThickness="1" CornerRadius="10" Padding="8,3" Margin="0,0,6,4">
                                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding KindText}" Foreground="{DynamicResource Accent}" FontSize="10"
                                                               FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Fg}" FontSize="11"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="220" />
                                                    <Button Content="✕" Command="{Binding $parent[ItemsControl].DataContext.RemoveAttachmentCommand}"
                                                            CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource FgFaint}"
                                                            BorderThickness="0" Padding="0" FontSize="9" Cursor="Hand"
                                                            AutomationProperties.Name="Remove attachment" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Context toolbar: @-reference + attach file · mode selector.
                                     A WrapPanel so the controls reflow (never overlap) in narrow columns. -->
                                <WrapPanel Orientation="Horizontal">
                                    <TextBox Text="{Binding ReferenceInput, Mode=TwoWay}" Width="180" Watermark="@ file or url…"
                                             Margin="0,0,6,6"
                                             Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                             BorderBrush="{DynamicResource Line}" CornerRadius="7" Padding="9,4" FontSize="12"
                                             AutomationProperties.Name="Add a context reference">
                                        <TextBox.KeyBindings>
                                            <KeyBinding Gesture="Enter" Command="{Binding AddReferenceCommand}" />
                                        </TextBox.KeyBindings>
                                    </TextBox>
                                    <Button Content="Add" Command="{Binding AddReferenceCommand}" Margin="0,0,6,6"
                                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="10,4" FontSize="12" />
                                    <Button Content="Attach file…" Click="OnAttachFile" Margin="0,0,6,6"
                                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="10,4" FontSize="12"
                                            AutomationProperties.Name="Attach a file or image" />

                                    <!-- mode selector (Ask / Code / …) -->
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                                Margin="4,0,0,6" IsVisible="{Binding HasModes}">
                                        <TextBlock Text="Mode" Foreground="{DynamicResource FgFaint}" FontSize="11" VerticalAlignment="Center" />
                                        <ItemsControl ItemsSource="{Binding Modes}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="4" /></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding Name}"
                                                            Command="{Binding $parent[ItemsControl].DataContext.SetModeCommand}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                                                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7"
                                                            Padding="10,4" FontSize="12" AutomationProperties.Name="Switch mode" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="{Binding CurrentModeName}" Foreground="{DynamicResource Accent}" FontSize="11"
                                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="2,0,0,0" />
                                    </StackPanel>
                                </WrapPanel>

                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBox x:Name="Composer" Text="{Binding PromptText, Mode=TwoWay}"
                                             Watermark="Message the agent…    (drag files or paste an image/file to attach)"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             MinHeight="88" MaxHeight="280" VerticalContentAlignment="Top"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             Background="{DynamicResource PanelAlt}" Foreground="{DynamicResource Fg}"
                                             BorderBrush="{DynamicResource Line}" CornerRadius="10" Padding="12,10"
                                             AutomationProperties.Name="Message the agent">
                                        <TextBox.KeyBindings>
                                            <KeyBinding Gesture="Ctrl+Enter" Command="{Binding SendCommand}" />
                                            <KeyBinding Gesture="Meta+Enter" Command="{Binding SendCommand}" />
                                            <KeyBinding Gesture="Ctrl+Shift+Enter" Command="{Binding SendNowCommand}" />
                                            <KeyBinding Gesture="Alt+Up" Command="{Binding RecallPreviousCommand}" />
                                            <KeyBinding Gesture="Alt+Down" Command="{Binding RecallNextCommand}" />
                                        </TextBox.KeyBindings>
                                    </TextBox>
                                    <!-- Live hint: Ctrl+Enter sends when idle but QUEUES while a turn runs, so
                                         the gesture's current meaning is always spelled out (defect #5). -->
                                    <TextBlock Text="{Binding SendGestureHint}" Foreground="{DynamicResource FgFaint}"
                                               FontSize="10" Margin="2,0,0,0" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Spacing="6" Width="92">
                                        <!-- Idle: Send -->
                                        <Button Content="Send" Command="{Binding SendCommand}" IsVisible="{Binding !IsTurnActive}"
                                                Height="40" HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                Background="{DynamicResource Accent}" Foreground="#1A1200" CornerRadius="10"
                                                FontWeight="SemiBold" AutomationProperties.Name="Send message" />
                                        <!-- Running: Queue / Send now / Stop -->
                                        <Button Content="Queue" Command="{Binding SendCommand}" IsVisible="{Binding IsTurnActive}"
                                                Height="34" HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                Background="{DynamicResource Accent}" Foreground="#1A1200" CornerRadius="10"
                                                FontWeight="SemiBold" AutomationProperties.Name="Queue this prompt"
                                                ToolTip.Tip="Send after the current turn finishes" />
                                        <Button Content="Send now" Command="{Binding SendNowCommand}" IsVisible="{Binding IsTurnActive}"
                                                Height="30" HorizontalAlignment="Stretch" FontSize="12"
                                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                Background="Transparent" Foreground="{DynamicResource FgDim}"
                                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8"
                                                AutomationProperties.Name="Stop the current turn and send now"
                                                ToolTip.Tip="Stop the current turn and send now" />
                                        <Button Command="{Binding CancelCommand}" IsVisible="{Binding IsTurnActive}"
                                                Height="30" HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                Background="Transparent" Foreground="{DynamicResource Fg}"
                                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8"
                                                AutomationProperties.Name="Stop the running turn" ToolTip.Tip="Stop the running turn">
                                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                                <Border Width="9" Height="9" CornerRadius="2" Background="{DynamicResource Accent}" />
                                                <TextBlock Text="Stop" VerticalAlignment="Center" FontSize="12" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <GridSplitter Grid.Column="3" Width="5" ResizeDirection="Columns"
                                  Background="{DynamicResource Line}" IsVisible="{Binding ShowRightPanel}" />

                    <!-- RIGHT: full preview (diff viewer or text) -->
                    <Border Grid.Column="4" IsVisible="{Binding ShowRightPanel}"
                            Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1,0,0,0">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="14,10">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding SelectedPreview.Title}" Foreground="{DynamicResource Fg}"
                                               FontWeight="SemiBold" VerticalAlignment="Center" FontFamily="{StaticResource MonoFont}"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="1" Command="{Binding SelectedPreview.ToggleSplitCommand}"
                                            IsVisible="{Binding SelectedPreview.IsDiff}"
                                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6"
                                            Padding="9,2" FontSize="11" Margin="0,0,8,0"
                                            ToolTip.Tip="Toggle split / unified diff" AutomationProperties.Name="Toggle split diff">
                                        <Panel>
                                            <TextBlock Text="Split" IsVisible="{Binding SelectedPreview.ShowUnified}" />
                                            <TextBlock Text="Unified" IsVisible="{Binding SelectedPreview.ShowSplit}" />
                                        </Panel>
                                    </Button>
                                    <Button Grid.Column="2" Content="Copy" Click="OnCopyPreview"
                                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6"
                                            Padding="9,2" FontSize="11" Margin="0,0,8,0"
                                            ToolTip.Tip="Copy the contents to the clipboard" AutomationProperties.Name="Copy preview contents" />
                                    <Button Grid.Column="3" Content="Full screen" Command="{Binding ToggleFullScreenCommand}"
                                            Background="Transparent" Foreground="{DynamicResource FgDim}"
                                            BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6"
                                            Padding="9,2" FontSize="11" Margin="0,0,8,0"
                                            ToolTip.Tip="Toggle full-screen review" AutomationProperties.Name="Toggle full-screen review" />
                                    <Button Grid.Column="4" Content="✕" Command="{Binding ClosePreviewCommand}"
                                            Background="Transparent" Foreground="{DynamicResource FgDim}" BorderThickness="0"
                                            Padding="8,2" FontSize="13" AutomationProperties.Name="Close preview" />
                                </Grid>
                            </Border>

                            <!-- Unified diff view -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          IsVisible="{Binding SelectedPreview.ShowUnified}">
                                <ItemsControl ItemsSource="{Binding SelectedPreview.Diff}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes.add="{Binding IsAdded}" Classes.del="{Binding IsRemoved}"
                                                    Classes.hunk="{Binding IsHunk}">
                                                <Grid ColumnDefinitions="40,40,14,*">
                                                    <TextBlock Grid.Column="0" Text="{Binding OldLineText}" TextAlignment="Right"
                                                               Foreground="{DynamicResource Gutter}" FontFamily="{StaticResource MonoFont}"
                                                               FontSize="11" Padding="0,1,6,1" />
                                                    <TextBlock Grid.Column="1" Text="{Binding NewLineText}" TextAlignment="Right"
                                                               Foreground="{DynamicResource Gutter}" FontFamily="{StaticResource MonoFont}"
                                                               FontSize="11" Padding="0,1,6,1" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Marker}" Foreground="{DynamicResource FgDim}"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="12" Padding="0,1" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Text}" Foreground="{DynamicResource Fg}"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="12" Padding="2,1,8,1"
                                                               TextWrapping="Wrap" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Split (side-by-side) diff view -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                          IsVisible="{Binding SelectedPreview.ShowSplit}">
                                <ItemsControl ItemsSource="{Binding SelectedPreview.SplitRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,*">
                                                <!-- old (left) -->
                                                <Border Grid.Column="0" Classes.del="{Binding LeftRemoved}" Classes.hunk="{Binding IsHunk}">
                                                    <Grid ColumnDefinitions="40,*">
                                                        <TextBlock Grid.Column="0" Text="{Binding LeftNo}" TextAlignment="Right"
                                                                   Foreground="{DynamicResource Gutter}" FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="11" Padding="0,1,6,1" />
                                                        <TextBlock Grid.Column="1" Text="{Binding LeftText}" Foreground="{DynamicResource Fg}"
                                                                   FontFamily="{StaticResource MonoFont}" FontSize="12" Padding="2,1,8,1"
                                                                   IsVisible="{Binding !IsHunk}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding HeaderText}" Foreground="{DynamicResource HunkFg}"
                                                                   FontFamily="{StaticResource MonoFont}" FontSize="12" Padding="2,1,8,1"
                                                                   IsVisible="{Binding IsHunk}" />
                                                    </Grid>
                                                </Border>
                                                <!-- new (right) -->
                                                <Border Grid.Column="1" Classes.add="{Binding RightAdded}" Classes.hunk="{Binding IsHunk}">
                                                    <Grid ColumnDefinitions="40,*">
                                                        <TextBlock Grid.Column="0" Text="{Binding RightNo}" TextAlignment="Right"
                                                                   Foreground="{DynamicResource Gutter}" FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="11" Padding="0,1,6,1" />
                                                        <TextBlock Grid.Column="1" Text="{Binding RightText}" Foreground="{DynamicResource Fg}"
                                                                   FontFamily="{StaticResource MonoFont}" FontSize="12" Padding="2,1,8,1" />
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Markdown preview (chat messages: tables, code, lists, …) -->
                            <mdxaml:MarkdownScrollViewer Grid.Row="1" Padding="16" Markdown="{Binding SelectedPreview.Body}"
                                                         IsVisible="{Binding SelectedPreview.IsMarkdown}"
                                                         SelectionEnabled="True" ctl:SelectionContextMenu.Enable="True" />

                            <!-- Plain, verbatim text preview (tool output, logs) -->
                            <ScrollViewer Grid.Row="1" Padding="16" VerticalScrollBarVisibility="Auto"
                                          IsVisible="{Binding SelectedPreview.IsPlainText}">
                                <SelectableTextBlock Text="{Binding SelectedPreview.Body}" Foreground="{DynamicResource Fg}"
                                           FontSize="13" TextWrapping="Wrap" ctl:SelectionContextMenu.Enable="True" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
