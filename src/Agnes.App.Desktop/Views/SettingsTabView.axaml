<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="using:System"
             xmlns:ctl="using:Agnes.App.Desktop.Controls"
             x:Class="Agnes.App.Desktop.Views.SettingsTabView">

    <UserControl.Styles>
        <Style Selector="Button.navitem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
        </Style>
        <Style Selector="Button.navitem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PanelAlt}" />
        </Style>
        <Style Selector="Button.navitem.on">
            <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        </Style>
        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.scopeNote">
            <Setter Property="Foreground" Value="{DynamicResource FgFaint}" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style Selector="TextBlock.fieldLabel">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style Selector="TextBlock.navGroup">
            <Setter Property="Foreground" Value="{DynamicResource FgFaint}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="10,12,0,3" />
        </Style>
    </UserControl.Styles>

    <Grid DataContext="{Binding Owner}" RowDefinitions="Auto,*" Background="{DynamicResource Bg}">

        <!-- Header + search -->
        <Border Grid.Row="0" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}"
                BorderThickness="0,0,0,1" Padding="24,16">
            <StackPanel Spacing="10">
                <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" />
                <Border Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                        CornerRadius="8" Padding="10,2" Width="340" HorizontalAlignment="Left">
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="12" Foreground="{DynamicResource FgFaint}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" Text="{Binding SettingsSearch, Mode=TwoWay}" Watermark="Search settings…"
                                 Background="Transparent" BorderThickness="0" FontSize="13" Padding="0,6" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="220,*">

            <!-- LEFT NAV -->
            <ScrollViewer Grid.Column="0" Background="{DynamicResource Panel}" Padding="10,10">
                <ItemsControl ItemsSource="{Binding SettingsCategories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Classes="navitem" Classes.on="{Binding IsSelected}" IsVisible="{Binding IsVisible}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Command="{Binding $parent[ItemsControl].DataContext.SetSettingsCategoryCommand}"
                                    CommandParameter="{Binding Id}">
                                <StackPanel Orientation="Horizontal" Spacing="9">
                                    <TextBlock Text="{Binding Icon}" FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- CONTENT -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="1000" Margin="32,24,32,48" Spacing="14" HorizontalAlignment="Stretch">

                    <!-- APPEARANCE (this device) -->
                    <StackPanel Spacing="12" IsVisible="{Binding CatAppearance}">
                        <TextBlock Classes="sectionTitle" Text="Appearance" />
                        <TextBlock Classes="scopeNote" Text="These apply to this app on this device." />

                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Classes="fieldLabel" Text="Theme" VerticalAlignment="Center" />
                                <ctl:InfoHint Description="The app's colour scheme. System follows your OS light/dark setting; Light and Dark pin it." />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="System" Command="{Binding SetThemeCommand}" CommandParameter="System" Classes.on="{Binding IsSystemTheme}" Classes="seg" />
                                <Button Content="Light" Command="{Binding SetThemeCommand}" CommandParameter="Light" Classes.on="{Binding IsLightTheme}" Classes="seg" />
                                <Button Content="Dark" Command="{Binding SetThemeCommand}" CommandParameter="Dark" Classes.on="{Binding IsDarkTheme}" Classes="seg" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Classes="fieldLabel" Text="UI scale" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="Small" Command="{Binding SetScaleCommand}" CommandParameter="small" Classes.on="{Binding IsScaleSmall}" Classes="seg" />
                                <Button Content="Default" Command="{Binding SetScaleCommand}" CommandParameter="default" Classes.on="{Binding IsScaleDefault}" Classes="seg" />
                                <Button Content="Large" Command="{Binding SetScaleCommand}" CommandParameter="large" Classes.on="{Binding IsScaleLarge}" Classes="seg" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <CheckBox IsChecked="{Binding ReducedMotion, Mode=TwoWay}" Foreground="{DynamicResource Fg}" Content="Reduce motion" />
                            <ctl:InfoHint Description="Minimises non-essential animation. Helpful for motion sensitivity or lower-powered displays." />
                        </StackPanel>
                    </StackPanel>

                    <!-- KEYBOARD (this device) -->
                    <StackPanel Spacing="10" IsVisible="{Binding CatKeyboard}">
                        <TextBlock Classes="sectionTitle" Text="Keyboard shortcuts" />
                        <StackPanel Spacing="5">
                            <TextBlock Text="Ctrl+T  New tab · Ctrl+W  Close tab · Ctrl+Tab  Next tab" Foreground="{DynamicResource FgDim}" FontSize="12" />
                            <TextBlock Text="Ctrl+Enter  Send · Alt+↑/↓  Prompt history" Foreground="{DynamicResource FgDim}" FontSize="12" />
                            <TextBlock Text="Ctrl+F  Search · F3/Shift+F3  Next/prev match" Foreground="{DynamicResource FgDim}" FontSize="12" />
                            <TextBlock Text="F8/F7  Next/prev prompt · Ctrl+F8/F7  Next/prev change" Foreground="{DynamicResource FgDim}" FontSize="12" />
                            <TextBlock Text="Ctrl+K  Command palette" Foreground="{DynamicResource FgDim}" FontSize="12" />
                        </StackPanel>
                    </StackPanel>

                    <!-- GITHUB (host) -->
                    <StackPanel Spacing="12" IsVisible="{Binding CatGitHub}">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="6">
                            <TextBlock Grid.Column="0" Classes="sectionTitle" Text="GitHub accounts" />
                            <ctl:InfoHint Grid.Column="1" Margin="6,0,0,0"
                                          Description="Link one or more GitHub accounts so sandboxed agents can push. Each push uses the account that owns the repo, and mints a token scoped to that one repo, ~1h TTL."
                                          Security="These accounts live on the host you're connected to, not this device. App private keys never enter a sandbox; agents get only a short-lived, repo-scoped token at push time, all audited." />
                            <Button Grid.Column="3" Content="Status" Command="{Binding LoadCredentialStatusCommand}" Classes="seg" />
                            <Button Grid.Column="4" Content="Connect account" Command="{Binding ConnectGitHubCommand}" Classes="seg" />
                        </Grid>
                        <TextBlock Classes="scopeNote">
                            <Run Text="Linked on the host:" /><Run Text=" " /><Run Text="{Binding ActiveHostName}" FontWeight="SemiBold" />
                        </TextBlock>
                        <TextBlock Text="{Binding CredentialStatus}" Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- DEVICES (host) -->
                    <StackPanel Spacing="12" IsVisible="{Binding CatDevices}">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                            <TextBlock Grid.Column="0" Classes="sectionTitle" Text="Devices" />
                            <ctl:InfoHint Grid.Column="1" Margin="6,0,0,0"
                                          Description="Every client paired with this host has its own token. Revoke one to cut off a lost or unwanted device without affecting the others."
                                          Security="Tokens are stored only as hashes on the host. Anyone holding a valid token has full access to this host's sessions." />
                            <Button Grid.Column="3" Content="Refresh" Command="{Binding LoadDevicesCommand}" Classes="seg" />
                        </Grid>
                        <TextBlock Classes="scopeNote">
                            <Run Text="Paired with the host:" /><Run Text=" " /><Run Text="{Binding ActiveHostName}" FontWeight="SemiBold" />
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding Devices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Fg}" FontSize="12" />
                                            <TextBlock Text="{Binding PairedAt, StringFormat='paired {0:yyyy-MM-dd}'}" Foreground="{DynamicResource FgFaint}" FontSize="10" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Revoke" FontSize="11" Padding="9,3" Background="Transparent" Foreground="#E5484D"
                                                BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6"
                                                Command="{Binding $parent[ItemsControl].DataContext.RevokeDeviceCommand}" CommandParameter="{Binding Id}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding DevicesStatus}" Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- SANDBOXES (managed VMs on the host) -->
                    <StackPanel Spacing="12" IsVisible="{Binding CatSandboxes}">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                            <TextBlock Grid.Column="0" Classes="sectionTitle" Text="Sandboxes" />
                            <ctl:InfoHint Grid.Column="1" Margin="6,0,0,0"
                                          Description="The sandbox VMs Agnes has created. Closing a session tab shuts its VM down (freeing CPU + RAM) but keeps it here so you can resume or delete it. A running VM uses host CPU/RAM; a stopped one only uses disk."
                                          Security="These are real VMs on the connected host. Delete destroys a sandbox and everything in it, permanently." />
                            <Button Grid.Column="3" Content="Refresh" Command="{Binding LoadSandboxesCommand}" Classes="seg" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Sandboxes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                                            CornerRadius="10" Padding="12,10" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="3">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Fg}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                                                    <Border CornerRadius="8" Padding="7,1" Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Line}"
                                                            BorderThickness="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding State}" FontSize="10" Foreground="{DynamicResource FgDim}" />
                                                    </Border>
                                                    <TextBlock Text="· live" FontSize="10" Foreground="{DynamicResource Good}" VerticalAlignment="Center" IsVisible="{Binding Live}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding WorkingDirectory}" Foreground="{DynamicResource FgFaint}" FontSize="10"
                                                           FontFamily="{StaticResource MonoFont}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding VmName, StringFormat='VM: {0}'}" Foreground="{DynamicResource FgFaint}" FontSize="10"
                                                           FontFamily="{StaticResource MonoFont}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <Button Content="Delete" Command="{Binding $parent[ItemsControl].DataContext.DeleteSandboxRecordCommand}"
                                                        CommandParameter="{Binding}" Background="Transparent" Foreground="#E5484D"
                                                        BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="10,4" FontSize="12" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding SandboxesStatus}" Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- PROJECTS (per-repo, on the host) -->
                    <StackPanel Spacing="12" IsVisible="{Binding CatProjects}">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                            <TextBlock Grid.Column="0" Classes="sectionTitle" Text="Projects" />
                            <ctl:InfoHint Grid.Column="1" Margin="6,0,0,0"
                                          Description="A project bundles what a session gets — its sandbox contents, MCP servers, GitHub account and defaults — keyed by the repo. A session in a repo uses that repo's project (auto-created the first time), so different repos get entirely different setups on the same host."
                                          Security="Projects and their sandbox images live on the host. Anything you add to a project's sandbox becomes available to that project's sandboxed agents." />
                            <Button Grid.Column="3" Content="Refresh" Command="{Binding LoadProjectsCommand}" Classes="seg" />
                        </Grid>
                        <TextBlock Text="{Binding ProjectsStatus}" Foreground="{DynamicResource FgFaint}" FontSize="11" TextWrapping="Wrap" />

                        <Grid ColumnDefinitions="240,*" ColumnSpacing="16">
                            <!-- Project list -->
                            <Border Grid.Column="0" Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="6" VerticalAlignment="Top">
                                <ItemsControl ItemsSource="{Binding Projects}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Classes="navitem" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                    Command="{Binding $parent[ItemsControl].DataContext.SelectProjectCommand}" CommandParameter="{Binding}">
                                                <StackPanel Spacing="1">
                                                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Fg}" FontSize="13" />
                                                    <TextBlock Text="{Binding RepoKey}" Foreground="{DynamicResource FgFaint}" FontSize="10" FontFamily="{StaticResource MonoFont}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <!-- Project editor -->
                            <StackPanel Grid.Column="1" Spacing="12" IsVisible="{Binding HasSelectedProject}">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="fieldLabel" Text="Name" />
                                    <TextBox Text="{Binding ProjName, Mode=TwoWay}" FontSize="13" Padding="8,5" CornerRadius="6" />
                                </StackPanel>

                                <Border Height="1" Background="{DynamicResource Line}" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Sandbox" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" VerticalAlignment="Center" />
                                    <ctl:InfoHint Description="What this project's VM image contains. Saving rebuilds it (a few minutes); sessions in this repo launch from it." />
                                </StackPanel>
                                <CheckBox IsChecked="{Binding ProjNode, Mode=TwoWay}" Foreground="{DynamicResource Fg}" Content="Install node + npm" />
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="fieldLabel" Text="apt packages" />
                                    <TextBox Text="{Binding ProjApt, Mode=TwoWay}" Watermark="git ripgrep cargo…" FontSize="12" Padding="8,5" CornerRadius="6" FontFamily="{StaticResource MonoFont}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="fieldLabel" Text="npm globals" />
                                    <TextBox Text="{Binding ProjNpm, Mode=TwoWay}" FontSize="12" Padding="8,5" CornerRadius="6" FontFamily="{StaticResource MonoFont}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="fieldLabel" Text="pip packages" />
                                    <TextBox Text="{Binding ProjPip, Mode=TwoWay}" FontSize="12" Padding="8,5" CornerRadius="6" FontFamily="{StaticResource MonoFont}" />
                                </StackPanel>

                                <Border Height="1" Background="{DynamicResource Line}" />
                                <TextBlock Text="MCP servers" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" />
                                <ItemsControl ItemsSource="{Binding ProjectMcp}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Fg}" FontSize="12" />
                                                    <TextBlock Foreground="{DynamicResource FgFaint}" FontSize="10">
                                                        <Run Text="{Binding Transport}" /><Run Text=" · run at " /><Run Text="{Binding RunAt}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="Remove" FontSize="11" Padding="9,3" Background="Transparent" Foreground="#E5484D"
                                                        BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6"
                                                        Command="{Binding $parent[ItemsControl].DataContext.RemoveProjectMcpCommand}" CommandParameter="{Binding}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="9">
                                    <StackPanel Spacing="6">
                                        <TextBox Text="{Binding NewMcpName, Mode=TwoWay}" Watermark="Server name" FontSize="12" Padding="8,5" CornerRadius="6" />
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Classes="fieldLabel" Text="Run at" VerticalAlignment="Center" />
                                            <Button Content="Host" Command="{Binding SetNewMcpRunAtCommand}" CommandParameter="host" Classes.on="{Binding NewMcpRunAtHost}" Classes="seg" />
                                            <Button Content="Sandbox" Command="{Binding SetNewMcpRunAtCommand}" CommandParameter="sandbox" Classes.on="{Binding NewMcpRunAtSandbox}" Classes="seg" />
                                            <TextBlock Classes="fieldLabel" Text="Transport" VerticalAlignment="Center" Margin="8,0,0,0" />
                                            <Button Content="stdio" Command="{Binding SetNewMcpTransportCommand}" CommandParameter="stdio" Classes.on="{Binding NewMcpIsStdio}" Classes="seg" />
                                            <Button Content="http" Command="{Binding SetNewMcpTransportCommand}" CommandParameter="http" Classes.on="{Binding NewMcpIsHttp}" Classes="seg" />
                                        </StackPanel>
                                        <StackPanel Spacing="6" IsVisible="{Binding NewMcpIsStdio}">
                                            <TextBox Text="{Binding NewMcpCommand, Mode=TwoWay}" Watermark="command (e.g. npx)" FontSize="12" Padding="8,5" CornerRadius="6" FontFamily="{StaticResource MonoFont}" />
                                            <TextBox Text="{Binding NewMcpArgs, Mode=TwoWay}" Watermark="args (space-separated)" FontSize="12" Padding="8,5" CornerRadius="6" FontFamily="{StaticResource MonoFont}" />
                                        </StackPanel>
                                        <TextBox IsVisible="{Binding NewMcpIsHttp}" Text="{Binding NewMcpUrl, Mode=TwoWay}" Watermark="https://server/mcp" FontSize="12" Padding="8,5" CornerRadius="6" FontFamily="{StaticResource MonoFont}" />
                                        <Button Content="Add server" Command="{Binding AddProjectMcpCommand}" HorizontalAlignment="Left" Classes="seg" />
                                    </StackPanel>
                                </Border>

                                <Border Height="1" Background="{DynamicResource Line}" />
                                <TextBlock Text="GitHub" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" />
                                <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="fieldLabel" Text="Account" VerticalAlignment="Center" />
                                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding GitHubAccounts}" SelectedItem="{Binding ProjAccount, Mode=TwoWay}" MinWidth="180" HorizontalAlignment="Left" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="fieldLabel" Text="Access" VerticalAlignment="Center" />
                                    <ComboBox Grid.Row="1" Grid.Column="1" SelectedItem="{Binding ProjGitMode, Mode=TwoWay}" MinWidth="140" HorizontalAlignment="Left"
                                              ToolTip.Tip="Off: no credentials. Ask: approve each repository once. Trust: allow every repo without asking.">
                                        <sys:String>Off</sys:String>
                                        <sys:String>Ask</sys:String>
                                        <sys:String>Trust</sys:String>
                                    </ComboBox>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="fieldLabel" Text="Checkout repo" VerticalAlignment="Top" Margin="0,6,0,0" />
                                    <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                                        <TextBox Text="{Binding ProjRepo, Mode=TwoWay}" Watermark="owner/repo or https://github.com/owner/repo (optional)"
                                                 FontSize="12" Padding="8,5" CornerRadius="6" FontFamily="{StaticResource MonoFont}" MinWidth="300" HorizontalAlignment="Left" />
                                        <TextBlock Text="Auto-cloned into the working directory before the agent launches (needs an account with access)."
                                                   Foreground="{DynamicResource FgFaint}" FontSize="10" TextWrapping="Wrap" MaxWidth="360" HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource Line}" />
                                <TextBlock Text="Defaults for new sessions" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" />
                                <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto" RowSpacing="8">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="fieldLabel" Text="MCP tools" VerticalAlignment="Center" />
                                    <ComboBox Grid.Row="0" Grid.Column="1" SelectedItem="{Binding ProjMcpApproval, Mode=TwoWay}" MinWidth="140" HorizontalAlignment="Left">
                                        <sys:String>Ask</sys:String>
                                        <sys:String>Trust</sys:String>
                                    </ComboBox>
                                    <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding ProjSkipPermissions, Mode=TwoWay}" Foreground="{DynamicResource Fg}" Content="Autonomous by default" />
                                </Grid>

                                <Button Content="Save project" Command="{Binding SaveProjectCommand}" HorizontalAlignment="Left" Classes="seg" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
