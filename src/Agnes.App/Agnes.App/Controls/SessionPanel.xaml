<UserControl
    x:Class="Agnes.App.Controls.SessionPanel"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="using:Agnes.App.Controls">

    <UserControl.Resources>
        <c:ObjectToVisibilityConverter x:Key="ObjectToVisibility" />
        <c:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <c:BoolToBubbleBrushConverter x:Key="BoolToBubbleBrush" />

        <DataTemplate x:Key="MessageTemplate">
            <Border Margin="0,4" Padding="12,8" CornerRadius="8"
                    Background="{Binding IsUser, Converter={StaticResource BoolToBubbleBrush}}">
                <StackPanel>
                    <TextBlock Text="{Binding Speaker}" FontSize="11" Opacity="0.6" Margin="0,0,0,2" />
                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ToolTemplate">
            <Border Margin="0,4" Padding="12,8" CornerRadius="8" BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE756;" FontSize="14" Opacity="0.7" />
                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding StatusText}" Opacity="0.6" />
                    </StackPanel>
                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Opacity="0.8"
                               Margin="0,4,0,0" FontFamily="Consolas" FontSize="12" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PlanTemplate">
            <Border Margin="0,4" Padding="12,8" CornerRadius="8" BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                <StackPanel>
                    <TextBlock Text="Plan" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                    <TextBlock Text="{Binding Status}" Opacity="0.6" FontSize="12" Width="90" />
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PermissionTemplate">
            <Border Margin="0,4" Padding="12,8" CornerRadius="8" BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}">
                <StackPanel>
                    <TextBlock Text="Permission requested" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding ResolutionText}" Opacity="0.7" Margin="0,4,0,0"
                               Visibility="{Binding ResolutionText, Converter={StaticResource ObjectToVisibility}}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="NoticeTemplate">
            <TextBlock Text="{Binding Text}" Opacity="0.7" FontStyle="Italic" Margin="0,4" TextWrapping="Wrap" />
        </DataTemplate>

        <c:TranscriptItemTemplateSelector x:Key="ItemSelector"
            Message="{StaticResource MessageTemplate}"
            Tool="{StaticResource ToolTemplate}"
            Plan="{StaticResource PlanTemplate}"
            Permission="{StaticResource PermissionTemplate}"
            Notice="{StaticResource NoticeTemplate}" />
    </UserControl.Resources>

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title + activity + mode -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Border Padding="8,2" CornerRadius="9" BorderThickness="1"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ActivityText}" FontSize="11" />
                </Border>
            </StackPanel>
            <ItemsControl Grid.Column="1" ItemsSource="{Binding Modes}"
                          Visibility="{Binding HasModes, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="4" /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Name}"
                                Command="{Binding DataContext.SetModeCommand, ElementName=Root}"
                                CommandParameter="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Connection / session banner -->
        <Border Grid.Row="1" Padding="12,8" CornerRadius="8"
                Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                Visibility="{Binding ShowBanner, Converter={StaticResource BoolToVisibility}}">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding BannerText}" TextWrapping="Wrap" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Retry" Command="{Binding RetryCommand}"
                        Visibility="{Binding CanRetry, Converter={StaticResource BoolToVisibility}}" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Items}" ItemTemplateSelector="{StaticResource ItemSelector}" />
        </ScrollViewer>

        <!-- Permission bar: facts + the agent's actual options -->
        <Border Grid.Row="3" Padding="12,8" CornerRadius="8"
                Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                Visibility="{Binding PendingPermission, Converter={StaticResource ObjectToVisibility}}">
            <StackPanel Spacing="6">
                <TextBlock Text="{Binding PendingPermission.Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                <TextBlock Text="{Binding PendingPermission.ReversibleText}" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding PendingPermission.Options}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="6" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                    Command="{Binding DataContext.RespondWithCommand, ElementName=Root}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Queued prompts -->
        <ItemsControl Grid.Row="4" ItemsSource="{Binding PendingPrompts}"
                      Visibility="{Binding HasQueue, Converter={StaticResource BoolToVisibility}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="8" Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Text}" Opacity="0.8" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="✕"
                                Command="{Binding DataContext.RemoveQueuedCommand, ElementName=Root}"
                                CommandParameter="{Binding}" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Prompt bar: Send when idle, Stop while a turn runs -->
        <Grid Grid.Row="5" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" PlaceholderText="Message the agent…"
                     Text="{Binding PromptText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" />
            <Button Grid.Column="1" Content="Send" Command="{Binding SendCommand}"
                    Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Stretch"
                    Visibility="{Binding IsTurnActive, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}" />
            <Button Grid.Column="1" Content="Stop" Command="{Binding CancelCommand}" VerticalAlignment="Stretch"
                    Visibility="{Binding IsTurnActive, Converter={StaticResource BoolToVisibility}}" />
        </Grid>
    </Grid>
</UserControl>
