<UserControl
    x:Class="Agnes.App.Controls.ConnectPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="8" Padding="4">
            <TextBlock Text="Agnes" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="Connect to a host" Opacity="0.7" />

            <TextBox Header="Host URL" Text="{Binding HostUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <PasswordBox Header="Pairing token" Password="{Binding Token, Mode=TwoWay}" />
            <TextBox Header="Working directory (on host)" Text="{Binding WorkingDirectory, Mode=TwoWay}" />

            <Button Content="Connect" Command="{Binding ConnectCommand}"
                    HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" />
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Opacity="0.8" />

            <TextBlock Text="Agents" FontWeight="SemiBold" Margin="0,8,0,0" />
            <ItemsControl ItemsSource="{Binding Agents}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding OpenCommand}" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left" Margin="0,2">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding HostUrl}" FontSize="11" Opacity="0.6" />
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
